    local mark="${TMPDIR:-/tmp}/zsh-bottom.$(stat -f %i ${TTY:-/dev/null} 2>/dev/null).$UID"
    if [[ ! -e $mark ]]; then
      repeat $LINES print
      : >| $mark
    fi
  }
fi

