# ~/.zshrc - interactive shell config
# Profile with: ZSH_DEBUGRC=1 zsh -i -c exit

[[ -n "${ZSH_DEBUGRC+1}" ]] && zmodload zsh/zprof

# ─── Bytecode compile hot files (auto-regen when source changes) ──────────
# zsh transparently uses .zwc if newer than source. Edits Just Work.
# Note: _cache_init compiles ~/.cache/zsh/*.zsh inline at write-time, so
# this loop only handles files _cache_init doesn't manage.
() {
  local f
  for f in ~/.zshrc ~/.zsh_plugins.zsh; do
    [[ -f $f && ( ! -f ${f}.zwc || $f -nt ${f}.zwc ) ]] && \
      zcompile -R -- ${f}.zwc $f 2>/dev/null
  done
}

# ─── History ──────────────────────────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory hist_ignore_dups hist_ignore_space share_history

# ─── Completion (must init BEFORE plugins so compdef is defined) ─────────
# Homebrew completions live here; add to fpath before compinit. (.zprofile
# inlines brew env to avoid a ruby fork, so it skips the fpath line that
# `brew shellenv` would normally emit — restore it here.)
fpath=("${HOMEBREW_PREFIX:-/opt/homebrew}/share/zsh/site-functions" $fpath)

# -C: skip security check + skip dump regen. Run `compinit` manually after
# installing tools that ship completions, or `rm ~/.zcompdump` to force rebuild.
autoload -Uz compinit
compinit -C -d "${ZDOTDIR:-$HOME}/.zcompdump"

# ─── Antidote (plugin manager) ────────────────────────────────────────────
source ~/.antidote/antidote.zsh

zsh_plugins=${ZDOTDIR:-~}/.zsh_plugins
[[ -f ${zsh_plugins}.txt ]] || touch ${zsh_plugins}.txt

# Regenerate static bundle when plugin list changes
if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]]; then
  autoload -Uz antidote
  antidote bundle <${zsh_plugins}.txt >|${zsh_plugins}.zsh
fi
source ${zsh_plugins}.zsh

# Catppuccin syntax-highlighting theme (after fast-syntax-highlighting loads)
source ~/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh

# Custom completions (after compinit + plugins)
compdef _gnu_generic pihole

# ─── Cached tool inits ────────────────────────────────────────────────────
# `_cache_init` lives in ~/.zsh/_cache_init.zsh so .zprofile can use it too
# (for `pyenv init --path` PATH setup at login). Re-sourcing here is
# idempotent and covers non-login interactive shells.
source "$HOME/.zsh/_cache_init.zsh"
_cache_init starship "starship init zsh"
# _ZO_DOCTOR=0: silence zoxide's "configuration issue" false-positive in
# Claude Code shells. Claude replays a shell snapshot that restores function
# defs but not the chpwd_functions hook array, so `z` thinks the hook is
# missing. Interactive shells register the hook correctly; the check is moot.
export _ZO_DOCTOR=0
_cache_init zoxide   "zoxide init zsh"
_cache_init direnv   "direnv hook zsh"

# ─── Keybindings ──────────────────────────────────────────────────────────
bindkey '^X'   create_completion
bindkey '^I'   autosuggest-accept       # tab          | complete
bindkey '^[[Z' complete-word            # shift + tab  | autosuggest

# ─── Lazy loaders for heavy tools ─────────────────────────────────────────

# nvm (brew-installed)
export NVM_DIR="$HOME/.nvm"
_load_nvm() {
  unset -f nvm 2>/dev/null
  [[ -s "{{ .homebrew_prefix }}/opt/nvm/nvm.sh" ]] && source "{{ .homebrew_prefix }}/opt/nvm/nvm.sh"
  [[ -s "{{ .homebrew_prefix }}/opt/nvm/etc/bash_completion.d/nvm" ]] && source "{{ .homebrew_prefix }}/opt/nvm/etc/bash_completion.d/nvm"
}
nvm() { _load_nvm; nvm "$@"; }

# pyenv shell function + completion (lazy: fires on first `pyenv` call).
# Shims are already on PATH from .zprofile's cached `pyenv init --path`, so
# `python`/`pip`/`aider` etc. work without firing this. We only need the
# shell function here for `pyenv shell` (sets PYENV_VERSION) + completion.
# `--no-rehash zsh`: skip rehash fork + skip shell detection (~40% faster).
_load_pyenv() {
  unset -f pyenv 2>/dev/null
  eval "$(command pyenv init - --no-rehash zsh)"
}
pyenv() { _load_pyenv; pyenv "$@"; }

# conda (~200ms hot)
_load_conda() {
  unset -f conda 2>/dev/null
  __conda_setup="$('{{ .homebrew_prefix }}/Caskroom/miniforge/base/bin/conda' 'shell.zsh' 'hook' 2>/dev/null)"
  if [[ $? -eq 0 ]]; then
    eval "$__conda_setup"
  elif [[ -f "{{ .homebrew_prefix }}/Caskroom/miniforge/base/etc/profile.d/conda.sh" ]]; then
    source "{{ .homebrew_prefix }}/Caskroom/miniforge/base/etc/profile.d/conda.sh"
  else
    export PATH="{{ .homebrew_prefix }}/Caskroom/miniforge/base/bin:$PATH"
  fi
  unset __conda_setup
}
conda() { _load_conda; conda "$@"; }

# sdkman
export SDKMAN_DIR="$HOME/.sdkman"
_load_sdkman() {
  unset -f sdk 2>/dev/null
  [[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]] && source "$SDKMAN_DIR/bin/sdkman-init.sh"
}
sdk() { _load_sdkman; sdk "$@"; }

# gh copilot aliases (forks subshell on each shell start - lazy)
_load_gh_copilot() {
  unset -f ghcs ghce 2>/dev/null
  eval "$(command gh copilot alias -- zsh)"
}
ghcs() { _load_gh_copilot; ghcs "$@"; }
ghce() { _load_gh_copilot; ghce "$@"; }

# opam (eager - <1ms total, but env_hook MUST install precmd before first
# prompt so `cd` into an OCaml project auto-activates the right switch env)
[[ -r "$HOME/.opam/opam-init/init.zsh" ]] && source "$HOME/.opam/opam-init/init.zsh" >/dev/null 2>&1

# gcloud completion (eager - 64 lines / 2KB, sub-ms cost)
# PATH for gcloud bin is set in .zprofile; this only adds tab-completion.
[[ -r "$HOME/google-cloud-sdk/completion.zsh.inc" ]] && source "$HOME/google-cloud-sdk/completion.zsh.inc"

# bun completions (~1ms - keep eager since tiny)
[[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"

# atuin (defer to after first prompt for speed)
. "$HOME/.atuin/bin/env"
zsh-defer eval "$(atuin init zsh)"

# broot (defer)
zsh-defer source "$HOME/.config/broot/launcher/bash/br"

# ─── GPG ──────────────────────────────────────────────────────────────────
# $TTY is a zsh builtin param - no fork needed (vs $(tty))
export GPG_TTY=$TTY

# ─── Aliases ──────────────────────────────────────────────────────────────
alias clear="clear && printf '\n%.0s' {1..100}"
alias c=clear
alias hh="cd ~ && c"
alias cleardns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
alias lvl="echo \"shlvl: \$((\$SHLVL-1))\""
alias shlvl=lvl
alias gitui="gitui -t mocha.ron"
alias cops="gh copilot suggest -t shell"
alias ls="eza --icons --group-directories-first"
alias cd=z
alias m="mutagen"
alias pb="pbcopy"
alias pbp="pbpaste"
alias occ="oc -c"
alias cmc="chezmoi-commit"  # AI-grouped chezmoi commits + push
# ─── Functions ────────────────────────────────────────────────────────────
opencode() {
  for arg in "$@"; do
    [[ "$arg" != -* ]] && { command opencode "$@"; return; }
  done
  command opencode --port 0 "$@"
}
oc() { opencode "$@"; }

y() {
  local tmp cwd yazi_status
  tmp="$(mktemp -t "yazi-cwd.XXXXXX")" || return

  command yazi "$@" --cwd-file="$tmp"
  yazi_status=$?

  cwd="$(<"$tmp")"
  if [[ -n "$cwd" && "$cwd" != "$PWD" && -d "$cwd" ]]; then
    builtin cd -- "$cwd"
  fi

  command rm -f -- "$tmp"

  return "$yazi_status"
}

# Tier C — chezmoi drift indicator (background, authoritative).
#
# `_chezmoi_drift_check` runs from precmd at most once per 60s and asks
# `chezmoi verify` whether every managed live file matches its source.
# Result lives in ~/.cache/chezmoi-drift/state and is read by the
# starship segment.
#
# State file format: concatenated Pure-style glyphs. Empty = clean.
#   ~ = managed live file actually differs from chezmoi source     (verified)
#   * = chezmoi source repo has uncommitted git changes        (Pure: dirty)
#   ⇡ = chezmoi source repo has commits not pushed to remote   (Pure: ahead)
#   ⇣ = chezmoi source repo is behind its remote (pull needed) (Pure: behind)
#   ? = remote-fetch knowledge is stale: no successful fetch in >24h
#       (network/auth issue — `⇣` may not reflect current remote state)
# Example state contents: "~*⇣" = drift + uncommitted + behind remote.
#
# `~` is `chezmoi verify` (rc=0 ⇒ clean, rc!=0 ⇒ flag). This is the
# authoritative answer — catches content drift, file deletion, mode
# changes, symlink target changes, everything chezmoi tracks. Earlier
# versions reimplemented this with mtime+sha256 snapshots to avoid
# `chezmoi verify`'s op:// 1Password prompts; that constraint is gone
# (op CLI no longer needs a TTY in this setup).
#
# Cost: verify templates every managed file (~3s for ~260 files here).
# Acceptable because (a) it runs detached in a `&!` subshell so prompt
# latency is zero, and (b) the 60s throttle caps load. The stale-lock
# reclaim threshold (lock_max_age, 300s) is decoupled from this so a slow
# verify is never misjudged dead and double-run.
#
# Cache layout under ~/.cache/chezmoi-drift/ :
#   state       — current drift glyphs. Only ever written atomically
#                 (tmp + mv-rename) by the bg job, so the indicator
#                 NEVER flickers — readers see the last complete state
#                 until the next bg job replaces it.
#   last-check  — throttle marker. Touched by the parent shell to claim
#                 the 60s refresh window. Lives separately from `state`
#                 so claiming the window doesn't blank the indicator
#                 (the old impl truncated `state` itself, causing a
#                 visible flicker each minute).
#   lock/       — mkdir-mutex acquired by the bg job. Atomic across
#                 shells via mkdir(2) — if N shells fire precmd at the
#                 same instant, only one bg verify runs; the rest exit
#                 silently. Released via EXIT trap in the subshell.
#
# `_chezmoi_remote_fetch` (further down) runs from precmd at most once
# per 15 min and does a quiet `git fetch` in the background, so the ⇡/⇣
# state stays fresh. Disable with: `export CHEZMOI_DRIFT_NO_FETCH=1`.
#
# Edge cases:
#   - chezmoi managed config has a template error → verify rc!=0 → flag `~`.
#     This is conservative-correct: if we can't verify cleanliness, surface
#     it. Run `chezmoi verify` interactively to see the underlying error.
#   - No upstream branch on source repo → ⇡/⇣ silently skipped (not flagged).
#   - Network down / auth required → fetch fails silently, ⇣ reflects last
#     successful fetch's snapshot of upstream; `?` appears after 24h.
zmodload -F zsh/stat b:zstat 2>/dev/null
zmodload -F zsh/datetime p:EPOCHSECONDS 2>/dev/null
# $sysparams[pid] is the REAL pid inside `( ) &!` subshells (plain $$ stays the
# parent pid there), used for collision-free temp/reclaim names below.
zmodload -F zsh/system p:sysparams 2>/dev/null
# zsh builtin mkdir/rm/mv work in `&!` subshells where the command-hash
# table is empty and the /usr/bin equivalents would be "not found".
# `mv` is loaded too so the atomic state publish (tmp + mv-rename) stays
# fork-free and works even when PATH lacks coreutils.
zmodload -F zsh/files b:mkdir b:rm b:mv 2>/dev/null

_chezmoi_drift_check() {
  local cache="$HOME/.cache/chezmoi-drift"
  local result="$cache/state"
  local marker="$cache/last-check"
  local lockdir="$cache/lock"
  local max_age=60        # throttle window: at most one verify per shell per 60s
  local lock_max_age=300  # stale-lock reclaim; MUST exceed worst-case verify
                          # (~3s for ~260 files here) so a slow-but-live holder
                          # is never misjudged dead and double-verified.
  # If chezmoi vanished mid-session (uninstalled / dropped from PATH), clear a
  # previously-exported indicator instead of leaving stale glyphs on the prompt.
  (( ${+commands[chezmoi]} )) || { unset STARSHIP_CHEZMOI_DRIFT; return 0; }
  # Expose current cache content to starship via env var, every prompt.
  # `$(<file)` is zsh's no-fork file read. Empty/missing file → unset →
  # [env_var.STARSHIP_CHEZMOI_DRIFT] in starship.toml renders nothing.
  if [[ -s "$result" ]]; then
    export STARSHIP_CHEZMOI_DRIFT="$(<"$result")"
  else
    unset STARSHIP_CHEZMOI_DRIFT
  fi
  # Throttle via separate marker file (not $result) so claiming the window
  # doesn't blank the indicator. $result stays at the last known glyphs
  # until the bg job atomically replaces it via mv-rename.
  if [[ -f "$marker" ]]; then
    local -A s; zstat -L -H s +mtime "$marker" 2>/dev/null
    local age=$(( EPOCHSECONDS - ${s[mtime]:-0} ))
    (( age < max_age )) && return 0
  fi
  # Pre-resolve binary paths in the parent shell. The `&!` subshell loses
  # the command hash table, so `command FOO` fails with "command not found"
  # even when PATH is intact. Resolved absolute paths inherit cleanly.
  local git_bin="${commands[git]:-/usr/bin/git}"
  local chezmoi_bin="${commands[chezmoi]}"
  # Claim the 60s window for this shell. Other precmd calls in this shell
  # short-circuit on the fresh marker mtime; other shells likewise. The cache
  # dir is created here (not every prompt) — the throttle-fresh fast path above
  # writes nothing under $cache, so it needn't pay the mkdir syscall.
  mkdir -p "$cache"
  : >| "$marker"
  ( # Inter-shell mutex via mkdir(2), which is atomic. If another shell's
    # bg job already holds the lock, exit silently rather than racing —
    # otherwise N concurrent shells would all spawn `chezmoi verify`.
    # zsh/files mkdir + rm are builtins loaded above (fork-free, work in
    # `&!` where the command hash table is empty).
    #
    # Stale-lock recovery: if the lock dir is older than $lock_max_age, the
    # previous holder must be dead (typical bg job is ~3s). Reclaim it.
    # Without this, a SIGKILL'd bg job would deadlock all future refreshes.
    # Reclaim atomically: rename-then-delete so that if two shells both see the
    # same stale lock, only the one whose `mv` wins removes it; the loser's mv
    # fails (already moved) and it falls through to the mkdir below, which then
    # fails against the winner's fresh lock and returns — preserving the
    # one-verify-per-window mutex even in the cold-start/post-crash race.
    if [[ -d "$lockdir" ]]; then
      local -A ls; zstat -L -H ls +mtime "$lockdir" 2>/dev/null
      if (( EPOCHSECONDS - ${ls[mtime]:-0} > lock_max_age )); then
        local reclaim="$lockdir.reclaim.$sysparams[pid]$RANDOM"
        mv -- "$lockdir" "$reclaim" 2>/dev/null && rm -rf -- "$reclaim" 2>/dev/null
      fi
    fi
    mkdir "$lockdir" 2>/dev/null || return
    # Release the lock on every exit path including signals. Single-quoted so
    # $lockdir expands at trap-fire time (a stable local in this subshell) — no
    # expanded-path re-parse hazard if the cache path ever holds odd characters.
    trap 'rm -rf -- "$lockdir" 2>/dev/null' EXIT INT TERM HUP
    local drifted="" source_dir
    # Glyph ~ : authoritative content drift via `chezmoi verify`.
    # Returns 0 iff every managed live file matches its source. Catches
    # content edits, deletions, mode/permission changes, symlink targets.
    "$chezmoi_bin" verify >/dev/null 2>&1 || drifted+="~"
    # Glyphs * / ⇡ / ⇣ : git state of the chezmoi source repo.
    # We avoid invoking `chezmoi source-path` (slow, boots templater) and
    # use the canonical XDG default with a one-shot fallback.
    source_dir="$HOME/.local/share/chezmoi"
    # `rev-parse --git-dir` (not `[[ -d .git ]]`) so a source that is a git
    # worktree or submodule — where `.git` is a gitfile, not a dir — still
    # reports its git state instead of silently suppressing * / ⇡ / ⇣ / ?.
    "$git_bin" -C "$source_dir" rev-parse --git-dir >/dev/null 2>&1 \
      || source_dir=$("$chezmoi_bin" source-path 2>/dev/null)
    if "$git_bin" -C "$source_dir" rev-parse --git-dir >/dev/null 2>&1; then
      if [[ -n "$("$git_bin" -C "$source_dir" status --porcelain 2>/dev/null)" ]]; then
        drifted+="*"
      fi
      # Ahead/behind upstream → Pure '⇡' / '⇣'. Skip cleanly if no upstream.
      # ⇣ uses local-only ref comparison; freshness depends on the periodic
      # _chezmoi_remote_fetch hook below.
      if "$git_bin" -C "$source_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
        if [[ -n "$("$git_bin" -C "$source_dir" rev-list '@{u}..HEAD' 2>/dev/null)" ]]; then
          drifted+="⇡"
        fi
        if [[ -n "$("$git_bin" -C "$source_dir" rev-list 'HEAD..@{u}' 2>/dev/null)" ]]; then
          drifted+="⇣"
        fi
        # If we *had* a successful fetch but it's been >24h, ⇣ knowledge is
        # stale. Append "?" so the user can investigate network / SSH agent
        # / git auth. Suppressed when last-fetch-ok is absent (cold cache /
        # first fetch in flight) — give the 15-min cycle a chance to land
        # before alarming.
        local fetch_ok="$HOME/.cache/chezmoi/last-fetch-ok"
        if [[ -f "$fetch_ok" ]]; then
          local -A fs
          if zstat -L -H fs +mtime "$fetch_ok" 2>/dev/null; then
            (( EPOCHSECONDS - ${fs[mtime]:-0} > 86400 )) && drifted+="?"
          fi
        fi
      fi
    fi
    # Atomic write: tmpfile in the same dir + mv. Readers never see a
    # partial or empty $result — they see either the old state or the
    # new state, never an in-between. zsh/files mv is a builtin (fork-free,
    # loaded above). $sysparams[pid] gives a per-subshell-unique tmp name
    # ($$ stays the parent pid here, so concurrent bg jobs would collide).
    local tmp="$result.tmp.$sysparams[pid]$RANDOM"
    local old=""; [[ -f "$result" ]] && old="$(<"$result")"
    print -n "$drifted" >| "$tmp"
    mv -f -- "$tmp" "$result"
    # Live in-place refresh: if the glyphs actually changed, poke the shell
    # that spawned us so it redraws the prompt now — no Enter needed. zsh keeps
    # $$ = the parent's pid inside this subshell (verified), so this targets the
    # interactive shell, not the subshell. `kill` is a builtin (works in this
    # fork-free &! subshell); silent if the shell already exited. Skipping the
    # signal when unchanged avoids needless redraws every refresh cycle.
    [[ "$drifted" != "$old" ]] && kill -USR1 $$ 2>/dev/null
  ) &!
}

# ── Live in-place refresh for the drift indicator ───────────────────────────
# _chezmoi_drift_check's bg job sends SIGUSR1 to its spawning shell when the
# glyphs change. This trap re-reads the cache into the env var and, if we're
# sitting idle at the prompt, redraws it via `zle reset-prompt` — so the
# indicator updates the instant the ~3s verify finishes, with no keypress.
# starship's PROMPT is a live `$(starship prompt)` command substitution
# (prompt_subst), so reset-prompt re-reads STARSHIP_CHEZMOI_DRIFT fresh.
# While a command is running (not at the prompt) we only refresh the env var;
# the next prompt renders it. The _CHEZMOI_AT_PROMPT flag (set by a precmd that
# runs last, cleared by preexec) gates reset-prompt so it's only called while
# zle is active.
typeset -g _CHEZMOI_AT_PROMPT=0
TRAPUSR1() {
  local result="$HOME/.cache/chezmoi-drift/state"
  if [[ -s "$result" ]]; then
    export STARSHIP_CHEZMOI_DRIFT="$(<"$result")"
  else
    unset STARSHIP_CHEZMOI_DRIFT
  fi
  (( _CHEZMOI_AT_PROMPT )) && zle reset-prompt 2>/dev/null
}
_chezmoi_prompt_ready() { _CHEZMOI_AT_PROMPT=1; }  # precmd: about to show prompt
_chezmoi_prompt_busy()  { _CHEZMOI_AT_PROMPT=0; }  # preexec: command running

# Background fetch of the chezmoi source remote so the B flag in
# _chezmoi_drift_check stays fresh. Runs at most once per 15 minutes,
# fully detached. Failures (offline, auth required, network slow) are
# silent — we just keep the last successful refs.
_chezmoi_remote_fetch() {
  (( ${+commands[chezmoi]} )) || return 0
  [[ -z "$CHEZMOI_DRIFT_NO_FETCH" ]] || return 0
  local fetch_cache="$HOME/.cache/chezmoi/last-fetch"
  local fetch_ok="$HOME/.cache/chezmoi/last-fetch-ok"
  local max_age=900  # 15 min
  if [[ -f "$fetch_cache" ]]; then
    local -A s; zstat -L -H s +mtime "$fetch_cache" 2>/dev/null
    local age=$(( EPOCHSECONDS - ${s[mtime]:-0} ))
    (( age < max_age )) && return 0
  fi
  # Touch the marker NOW (parent shell) so we don't queue many
  # concurrent fetches if precmd fires repeatedly while one is in flight.
  mkdir -p "${fetch_cache:h}" && : >| "$fetch_cache"
  local git_bin="${commands[git]:-/usr/bin/git}"
  local chezmoi_bin="${commands[chezmoi]}"
  ( local source_dir="$HOME/.local/share/chezmoi"
    # rev-parse --git-dir handles worktree/submodule gitfiles too (see drift check).
    "$git_bin" -C "$source_dir" rev-parse --git-dir >/dev/null 2>&1 \
      || source_dir=$("$chezmoi_bin" source-path 2>/dev/null)
    "$git_bin" -C "$source_dir" rev-parse --git-dir >/dev/null 2>&1 || return
    "$git_bin" -C "$source_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' \
      >/dev/null 2>&1 || return
    # Cap a stalled fetch so it can't leave an orphan accumulating every 15 min.
    # GIT_HTTP_LOW_SPEED_LIMIT/TIME covers smart-HTTP(S) only — a no-op for SSH,
    # which is the remote actually in use (git@github.com). GIT_SSH_COMMAND adds
    # the SSH-transport equivalent: ConnectTimeout bounds the initial connect
    # (ssh defaults to none), ServerAlive* kills a mid-transfer stall, and
    # BatchMode prevents an interactive auth/passphrase prompt from blocking the
    # detached job forever (a failed fetch degrades gracefully — ⇣ goes stale,
    # then `?` after 24h). Scoped to this one fetch; not exported.
    if GIT_HTTP_LOW_SPEED_LIMIT=1000 GIT_HTTP_LOW_SPEED_TIME=15 \
       GIT_SSH_COMMAND='ssh -o BatchMode=yes -o ConnectTimeout=15 -o ServerAliveInterval=10 -o ServerAliveCountMax=2' \
       "$git_bin" -C "$source_dir" fetch --quiet --no-tags --prune 2>/dev/null
    then
      : >| "$fetch_ok"
    fi
  ) &!
}

# Starship job-state indicator: split stopped (Ctrl+Z'd) vs running (&) jobs.
# Starship's built-in `jobs` module is one count for everything, which hides
# the dangerous case (forgotten suspended job). We split it via two
# [env_var.*] modules in starship.toml; this hook keeps the env vars in sync
# with the parent shell's job table.
#
# Why env-var instead of file cache (like _chezmoi_drift_check):
# - $jobstates is already in zsh memory — zero fork, zero I/O.
# - chezmoi-drift caches because `chezmoi verify` is ~500ms; jobs are free.
# - Mirrors starship's own internal pattern: starship/src/init/starship.zsh
#   exports STARSHIP_JOBS_COUNT="${#jobstates[*]}" from its precmd hook.
#
# $jobstates is provided by zsh/parameter (force-load to be explicit; usually
# auto-loaded in interactive zsh). Keys look like "running:0=12345" /
# "suspended:0=12345"; the (M) flag matches and #...:#pat:* counts matches.
zmodload -F zsh/parameter p:jobstates 2>/dev/null

_starship_jobs_state() {
  local stopped=${(M)#jobstates:#suspended:*}
  local running=${(M)#jobstates:#running:*}
  if (( stopped > 0 )); then
    export STARSHIP_JOBS_STOPPED=$stopped
  else
    unset STARSHIP_JOBS_STOPPED
  fi
  if (( running > 0 )); then
    export STARSHIP_JOBS_RUNNING=$running
  else
    unset STARSHIP_JOBS_RUNNING
  fi
}

typeset -ga precmd_functions
# Guard against duplicate registration: zshrc may be re-sourced (login
# shell rebuild, exec zsh, tmux source-file with loaded panes, etc.).
# Without this, each precmd hook fires N times after the Nth re-source.
[[ -z "${precmd_functions[(r)_chezmoi_drift_check]}" ]] && \
  precmd_functions+=(_chezmoi_drift_check)
[[ -z "${precmd_functions[(r)_chezmoi_remote_fetch]}" ]] && \
  precmd_functions+=(_chezmoi_remote_fetch)
[[ -z "${precmd_functions[(r)_starship_jobs_state]}" ]] && \
  precmd_functions+=(_starship_jobs_state)
# Registered LAST so the at-prompt flag flips true only after all precmd work,
# right before the prompt draws — minimizing the window where a USR1 could fire
# with the flag set but zle not yet active.
[[ -z "${precmd_functions[(r)_chezmoi_prompt_ready]}" ]] && \
  precmd_functions+=(_chezmoi_prompt_ready)
typeset -ga preexec_functions
[[ -z "${preexec_functions[(r)_chezmoi_prompt_busy]}" ]] && \
  preexec_functions+=(_chezmoi_prompt_busy)

# Wrap chezmoi to keep the drift indicator in sync with reality. Drift
# detection is done by `chezmoi verify` (run from precmd), so the wrapper
# only needs to invalidate the result cache after subcommands that could
# have changed state — the next precmd then re-runs verify and updates
# the indicator. No snapshot file to maintain anymore.
chezmoi() {
  # Two passes over $@:
  #   PASS 1 — find the subcommand by skipping leading global flags. Some
  #     flags take a separate argument (`chezmoi --config /tmp/foo apply`),
  #     so the SEP_FLAGS whitelist consumes the next token. Stops at the
  #     first non-flag token (the subcommand). Anything with `=` form
  #     (`--config=/tmp/foo`) is a single token, no consume needed.
  #
  #   PASS 2 — scan the ENTIRE arg list for `--dry-run`/`-n`. Cobra/pflag
  #     accepts global flags both BEFORE and AFTER the subcommand:
  #     `chezmoi apply --dry-run` is the canonical form. Stopping at the
  #     subcommand (as a previous attempt did) misses this and the wrapper
  #     would silently resnapshot live state as "applied," absorbing any
  #     pre-existing drift into a falsely-clean snapshot.
  local cmd="" a
  # Whitelist of chezmoi global flags that take a separate argument. Without
  # an entry here, `chezmoi <flag> <value> <subcommand>` mis-parses <value>
  # as the subcommand → silently skips the post-apply resnapshot. Long and
  # short forms both listed because chezmoi accepts both freely.
  # Source: `chezmoi --help`. Keep aligned when chezmoi adds new globals.
  local -a SEP_FLAGS=(
    --config --config-format --source --destination --working-tree
    --cache --output --color --persistent-state --use-builtin-age --use-builtin-git
    --mode --age-recipient --age-recipient-file
    --override-data --override-data-file --progress
    -c -S -D -o
  )
  local skip_next=0
  for a in "$@"; do
    if (( skip_next )); then skip_next=0; continue; fi
    case "$a" in --) continue ;; esac
    if [[ "$a" == -* ]]; then
      if (( ${SEP_FLAGS[(I)$a]} )); then skip_next=1; fi
      continue
    fi
    cmd="$a"
    break
  done
  # Pass 2: scan for --dry-run / -n. Stop at `--` so positional args named
  # literally `--dry-run` (extremely unlikely but possible) aren't treated
  # as the flag and don't accidentally defer the snapshot refresh.
  local dry_run=0
  for a in "$@"; do
    case "$a" in
      --) break ;;
      --dry-run|-n) dry_run=1; break ;;
    esac
  done
  command chezmoi "$@"
  local rc=$?
  # Dry-run mutates nothing — leave the indicator cache alone.
  (( dry_run )) && return $rc
  # Read-only subcommands can't change drift state, so skip the re-verify they
  # would otherwise force (this is what PASS 1's $cmd is for — without this the
  # wrapper churned a background verify after every `chezmoi diff`/`status`/etc).
  # Conservative list: anything not clearly read-only still invalidates.
  local -a RO_CMDS=(
    cat data diff status verify managed source-path dump
    execute-template doctor help completion
  )
  [[ -n "$cmd" && -n "${RO_CMDS[(r)$cmd]}" ]] && return $rc
  # Invalidate the throttle marker so the NEXT precmd re-runs verify.
  # We deliberately do NOT delete `state` — that would blank the indicator
  # for the ~500ms window until the bg job finishes. Keeping the old state
  # visible until the atomic mv-rename swaps in fresh glyphs is the whole
  # point of the marker / state split.
  rm -f "$HOME/.cache/chezmoi-drift/last-check" 2>/dev/null
  return $rc
}

# `nvim ~/.zshrc` interception now lives in nvim, not zsh — see
# ~/.config/nvim/lua/chezmoi_workflow.lua. The nvim autocmd catches managed
# live paths from any entry point (zsh, bash, :e, Telescope, Oil, …) and
# swaps to the chezmoi source, with auto-apply on save. Same UX, broader
# coverage.

# ─── Visual: scroll prompt to bottom on shell open ────────────────────────
# Fire once per pty: each tmux pane / terminal tab is a unique pty, so this
# gives "new shell at bottom" UX without cascading in nested subshells (a
# `zsh` inside `zsh` reuses the parent pty → marker already exists → skipped).
#
# Previous guard `SHLVL == 1` was brittle: tmux server's inherited SHLVL
# depends on what launched it (wezterm → login zsh → tmux gives SHLVL=1 in
# the server, so panes get SHLVL=2 and the block silently skipped). After a
# reboot the SHLVL chain can shift by one and the indicator stops working.
#
# Marker layout: $TMPDIR/zsh-bottom.<pty-inode>.<uid>. /tmp clears on boot,
# so markers naturally reset every restart. $UID suffix avoids cross-user
# collisions if pty inodes are reused. `stat -f %i` is BSD-stat (macOS).
if [[ -t 1 ]]; then
  () {
    local mark="${TMPDIR:-/tmp}/zsh-bottom.$(stat -f %i ${TTY:-/dev/null} 2>/dev/null).$UID"
    if [[ ! -e $mark ]]; then
      repeat $LINES print
      : >| $mark
    fi
  }
fi

