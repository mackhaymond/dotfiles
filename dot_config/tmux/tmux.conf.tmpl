# Baseline PATH for every process tmux spawns (panes, popups, run-shell,
# and anything those launch in turn — including non-shell processes like
# opencode that exec children directly). Login-shell zsh further extends
# this via .zprofile, but non-shell child processes only see what's here.
# Keep this list aligned with the must-have tool dirs from .zprofile.
set-environment -g PATH "$HOME/.local/share/bob/nvim-bin:$HOME/.pyenv/shims:$HOME/.cargo/bin:$HOME/.bun/bin:$HOME/.local/bin:{{ .homebrew_prefix }}/bin:{{ .homebrew_prefix }}/sbin:/usr/bin:/bin:/usr/sbin:/sbin"

setw -g mode-keys vi

unbind r
bind r source-file ~/.config/tmux/tmux.conf

unbind C-b
set -g prefix C-s
set -g mouse on

set -g default-terminal "tmux-256color"
set-option -g terminal-overrides "linux*:AX@,xterm-256color:Tc"
set-option -g terminal-features "xterm*:clipboard:ccolour:cstyle:focus:title,screen*:title,rxvt*:ignorefkeys,xterm-256color:RGB:sixel"
set-option -g allow-passthrough all
set-option -g update-environment "DISPLAY KRB5CCNAME MSYSTEM SSH_ASKPASS SSH_AUTH_SOCK SSH_AGENT_PID SSH_CONNECTION WINDOWID XAUTHORITY TERM TERM_PROGRAM TERM_PROGRAM_VERSION"

set -g base-index 1
set -g pane-base-index 1
set-window-option -g pane-base-index 1
set-option -g renumber-windows on

set -g pane-border-lines heavy

#### end general setup ####


bind '"' split-window -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
bind c new-window -a -c "#{pane_current_path}"

# CMD+SHIFT+T (wezterm) → new tab at the end of all tabs, starting in $HOME.
bind C-t new-window -a -t '{end}' -c "#{HOME}"

# CMD+SHIFT+R (wezterm) → recreate current tab in place, same cwd.
bind R new-window -a -c "#{pane_current_path}" \; kill-window -t -

set -g status-position top

# List of plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-yank'

# catppuccin
set -g @plugin 'catppuccin/tmux#v0.2.0'
# battery module disabled; plugin not needed.
# set -g @plugin 'tmux-plugins/tmux-battery'
set -g @catppuccin_flavor 'mocha'

# Catppuccin expects an absolute custom module dir; expand #{HOME} at runtime.
set -gF @catppuccin_custom_plugin_dir "#{HOME}/.config/tmux/catppuccin-custom"

# Safe defaults for custom modules (can be overridden per-host).
set -g @codex_session_color "colour239"
set -g @codex_weekly_color "colour239"
set -g @codexbar_view "percent"

# Coffee (caffeinate) indicator disabled — module dropped from the status bar
# and the watcher (below) no longer spawned. Defaults left commented for revive.
# coffee-watcher.sh overwrites these whenever caffeination state changes and
# forces an immediate status redraw via refresh-client -S. Initial values are
# the "off" state so the chip renders cleanly before the watcher's first tick.
# The empty-pot glyph is U+F181B nf-md-coffee_maker_outline (Nerd Font v3,
# MesloLGS NF); overlay0 #6c7086 is a legible neutral gray (surface1 #45475a sat
# too close to the status bar's surface0 bg and the chip disappeared).
# set -g @coffee_glyph "󱠛"
# set -g @coffee_color "#209fb5"

# Codexbar defaults ("plugin-like" surface); setup script reads these.
# @codexbar_provider: "codex" delegates to the codexbar CLI tool against the
# codex provider. "claude" hits Anthropic's OAuth /api/oauth/usage endpoint
# directly (real session+weekly reset times).
set -g @codexbar_provider "codex"
set -g @codexbar_reset_key "u"
set -g @codexbar_reset_view_seconds "3"
set -g @codexbar_reset_view_scope "both"
set -g @codexbar_stale_after_seconds "120"
set -g @codexbar_debug "0"
set -g @codexbar_web_timeout "2"

# Ensure the old inline binding is removed on reload.
unbind u

# Bootstrap codexbar keybindings/usage via script.
run-shell "bash #{HOME}/.config/tmux/scripts/codexbar-usage-setup.sh"
run-shell -b "bash #{HOME}/.config/tmux/scripts/codexbar-usage-status.sh --tick"

# Coffee watcher disabled (caffeinate chip removed). Re-enable alongside the
# coffee module and @coffee_* defaults above. Spawned as a singleton; polls
# caffeination state at 500ms and pushes changes to tmux via refresh-client,
# so the chip flips near-instantly when Raycast Coffee toggles.
# run-shell -b "bash #{HOME}/.config/tmux/scripts/coffee-watcher.sh"

# set -g @catppuccin_status_modules_right "application session battery date_time"
# Coffee (caffeinate) and battery modules disabled.
# set -g @catppuccin_status_modules_right "directory codex_session codex_weekly session coffee battery"
set -g @catppuccin_status_modules_right "directory codex_session codex_weekly session"
set -g @catppuccin_date_time_text "%I:%M %p | %m-%d-%y"
set -g @catppuccin_status_left_separator "█"

set -g @catppuccin_window_middle_separator "█ "
set -g @catppuccin_window_right_separator "█"
set -g @catppuccin_window_number_position "left"
set -g @catppuccin_window_default_fill "number"
set -g @catppuccin_window_current_fill "number"
# Tab name + a leading dot recolor when an agent in that window needs input
# (yellow) or has finished (green). Driven by the per-window @agent_state option
# set from Claude Code hooks via scripts/agent-tab-indicator.sh. When unset the
# name renders with Catppuccin's normal fg. Mocha: yellow #f9e2af, green #a6e3a1.
set -g @catppuccin_window_default_text "#{?#{==:#{@agent_state},needs-input},#[fg=#f9e2af]● ,}#{?#{==:#{@agent_state},done},#[fg=#a6e3a1]● ,}#W"
set -g @catppuccin_window_current_text "#{?#{==:#{@agent_state},needs-input},#[fg=#f9e2af]● ,}#{?#{==:#{@agent_state},done},#[fg=#a6e3a1]● ,}#W"
# end catppuccin

# Clear a tab's agent tint the moment you switch to it (you've seen it).
set-hook -g after-select-window 'run-shell -b "#{HOME}/.config/tmux/scripts/agent-tab-indicator.sh clear-current"'

set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @resurrect-dir '{{ .chezmoi.homeDir }}/.tmux/resurrect'
set -g @resurrect-capture-pane-contents 'on'
set -g @resurrect-strategy-nvim 'session'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @continuum-save-interval '15'
set -g @continuum-restore 'on'

# Persist and resume assistant CLI sessions with tmux-resurrect/continuum.
set -g @plugin 'timvw/tmux-assistant-resurrect'
set -g @assistant-resurrect-capture-env 'VIRTUAL_ENV NODE_ENV CONDA_DEFAULT_ENV OPENCODE_CONFIG'

unbind-key a
bind-key a display-popup -E -w 60% -h 75% "$HOME/.config/tmux/scripts/mru-session-switch.sh"

unbind-key C-a
bind-key C-a display-popup -E -w 60% -h 75% "$HOME/.config/tmux/scripts/mru-session-switch.sh"

set -g @plugin '27medkamal/tmux-session-wizard'
set -g @session-wizard 'T'

set -g @plugin 'sainnhe/tmux-fzf'
TMUX_FZF_LAUNCH_KEY="C-m"

set -g @plugin 'omerxx/tmux-floax'
set -g @floax-bind '-n M-q'

unbind -n M-a
bind -n M-a run-shell -b "#{HOME}/.config/tmux/scripts/toggle-btop-popup.sh '#{client_tty}'"

unbind -n M-y

# bind -n m-w send-keys -F "yy" Enter

# bind -n m-q run-shell "~/code/various_scripts/popuptmux"

# Other examples:
# set -g @plugin 'github_username/plugin_name'
# set -g @plugin 'github_username/plugin_name#branch'
# set -g @plugin 'git@github.com:user/plugin'
# set -g @plugin 'git@bitbucket.com:user/plugin'


bind C-l kill-pane
# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'
