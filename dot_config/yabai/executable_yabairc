#vim:ft=bash
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config layout stack
yabai -m config window_origin_display focused
yabai -m config display_arrangement_order horizontal

yabai -m config window_shadow off

yabai -m config top_padding 0

YABAI_WORKSPACE_REFRESH="${HOME}/code/various_scripts/yabai_workspace_refresh.sh"
YABAI_DISPLAYS="${HOME}/code/various_scripts/yabai_displays.sh"
YABAI_MOUSE_FOLLOW="${HOME}/code/various_scripts/yabai_mouse_follow.sh"
YABAI_HEAL="${HOME}/code/various_scripts/yabai_heal.sh"
YABAI_STARTUP_RECONCILE="${HOME}/code/various_scripts/yabai_startup_reconcile.sh"
# Draw a JankyBorders border around FLOATING windows only (scope = all is-floating,
# incl. manage=off apps). `sync` reconciles the borders daemon to the current
# floating set; no-op if `borders` isn't installed. See yabai_float_borders.sh.
YABAI_FLOAT_BORDERS="${HOME}/code/various_scripts/yabai_float_borders.sh"
# One-shot, focus-safe refresh of the yabai_layers SwiftBar menu-bar plugin. name= is
# the base name before the first dot (interval-independent -- survives the .30s
# filename), -g never steals focus, /usr/bin/open is absolute (yabai actions run in a
# non-interactive shell), single-quoted so the shell doesn't glob the `?`.
YABAI_LAYERS_REFRESH="/usr/bin/open -g 'swiftbar://refreshplugin?name=yabai_layers'"
"$YABAI_WORKSPACE_REFRESH" startup

yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^BetterTouchTool$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^python$" manage=off
yabai -m rule --add app="^DaisyDisk$" manage=off
yabai -m rule --add app="^iStat Menus$" manage=off border=off
yabai -m rule --add app="^Steam$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Mail$" manage=off 
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^BetterZip$" manage=off 
yabai -m rule --add app="^DevPod$" manage=off 
yabai -m rule --add app="^Setapp$" manage=off 
yabai -m rule --add app="^Permute$" manage=off 
yabai -m rule --add app="^TI-Nspire$" manage=off
yabai -m rule --add app="^LiveMath Maker$" manage=off
yabai -m rule --add app="^Antidote$" manage=off

# window_created hook. The "terminal" space is NOT reserved -- other windows may
# land on it and stay (no bounce). This hook only: (1) re-pins the Arc MAIN
# windows via Hammerspoon on any new Arc window, and (2) nudges a NORMAL WezTerm
# onto the terminal space, since the space=terminal rule is racy at launch.
yabai -m signal --add event=window_created action='
  win=$YABAI_WINDOW_ID
  info=$(yabai -m query --windows --window "$win" 2>/dev/null) || exit 0
  # A new window may add a stack layer on the focused space -> bump the layers bar.
  /usr/bin/open -g "swiftbar://refreshplugin?name=yabai_layers"
  app=$(printf "%s" "$info" | jq -r ".app // empty" 2>/dev/null)
  # New Arc window -> re-pin the Arc MAIN windows via Hammerspoon (only it can
  # read AXIdentifier to tell a main window from a Little Arc popup). Same trigger
  # cadence as the other apps re-applying their space= rules. No-op if hs is down.
  [ "$app" = "Arc" ] && /opt/homebrew/bin/hs -c "arcSync()" >/dev/null 2>&1
  case "$app" in
    wezterm-gui|WezTerm)
      # WezTerm is a normal, NON-fullscreenable window (native_macos_fullscreen_mode
      # is off and the borderless RESIZE window has no macOS fullscreen action), so
      # in practice it is never fullscreen here. The is-native-fullscreen guard below
      # is kept DEFENSIVELY: if a WezTerm window ever were fullscreen, never drag it
      # onto a fixed space -- that would yank it out. Only nudge a NORMAL WezTerm onto
      # the terminal space (the space=terminal rule is racy at launch).
      nsfs=$(printf "%s" "$info" | jq -r '.["is-native-fullscreen"]' 2>/dev/null)
      [ "$nsfs" = "true" ] && exit 0
      wspace=$(printf "%s" "$info" | jq -r .space)
      wtidx=$(yabai -m query --spaces --space terminal 2>/dev/null | jq -r .index 2>/dev/null)
      case "$wtidx" in ""|*[!0-9]*) exit 0 ;; esac
      [ "$wspace" != "$wtidx" ] && yabai -m window "$win" --space terminal 2>/dev/null
      exit 0
      ;;
  esac
  # Any other app: leave it wherever it landed. The terminal space is no longer
  # reserved, so windows may share it with WezTerm.
  exit 0
'

# On every space change: keep the "terminal" label pinned to WezTerm wherever
# it is -- so when WezTerm enters/exits a macOS native-fullscreen Space the label
# follows it and stays in canonical order (yabai_terminal_follow.sh; cheap no-op
# when nothing moved).
yabai -m signal --add event=space_changed action='
  # Active space changed -> re-evaluate the layers bar for the new space (covers every
  # space switch, native-fullscreen enter/exit, and send-window-with-follow).
  /usr/bin/open -g "swiftbar://refreshplugin?name=yabai_layers"
  "$HOME/code/various_scripts/yabai_terminal_follow.sh"
  exit 0
'

# App -> Space pinning
yabai -m rule --add app="^(wezterm-gui|WezTerm)$" space=terminal
yabai -m rule --add app="^Todoist$" space=todo
yabai -m rule --add app="^Granola$" space=schedule
yabai -m rule --add app="^Spark Mail$" space=mail
yabai -m rule --add app="^Notion Calendar$" space=calendar
yabai -m rule --add app="^Messages$" space=messages
yabai -m rule --add app="^ChatGPT$" space=ai
yabai -m rule --add app="^Claude$" space=ai
yabai -m rule --add app="^Codex$" space=codex

# Re-apply rules to currently-open windows on yabai (re)start.
# Catches windows whose creation events were missed (login race, crash-restart).
yabai -m rule --apply

# Login-race reconciliation. The single rule --apply above can run before macOS has
# restored all app windows (or before --load-sa finishes), so pinned apps land on the
# wrong space until a manual restart. This re-asserts the rules + re-pins Arc a few
# times over the first ~30s as the session settles (see yabai_startup_reconcile.sh).
# BACKGROUNDED (&) so it never blocks yabai startup; idempotent once windows are home.
"$YABAI_STARTUP_RECONCILE" &

# Border any floating windows that already exist at startup (e.g. a manage=off app
# that macOS restored). Backgrounded; no-op if nothing floats / borders absent.
"$YABAI_FLOAT_BORDERS" sync &

# Belt-and-suspenders: re-fire rules on any app launch in case the
# window_created event is lost.
# Re-apply the space= rules (pins Todoist/Messages/etc.) AND re-pin the Arc main
# windows (Hammerspoon) on every app launch -- one consistent "snap" moment.
yabai -m signal --add event=application_launched action="yabai -m rule --apply; /opt/homebrew/bin/hs -c 'arcSync()' >/dev/null 2>&1"
# Display hotplug -> debounced handler (non-destructive on connect; pull-home
# on disconnect). Replaces the old "reset everything to the laptop" refresh.
yabai -m signal --add event=display_added label=workspace_display_added action="$YABAI_DISPLAYS added"
yabai -m signal --add event=display_removed label=workspace_display_removed action="$YABAI_DISPLAYS removed"

# When the ACTIVE display changes (any cross-display focus: F13/F14, push,
# home-all, master, or a focus bind whose label lives on the other screen),
# warp the mouse onto the now-focused display. Never fires with one display.
yabai -m signal --add event=display_changed label=mouse_follow_display action="$YABAI_MOUSE_FOLLOW"

# Event-driven self-heal. The canonical-label model breaks when a LABELED space is
# destroyed/merged (the classic label-drop -- e.g. a fullscreen collapse merging an
# adjacent space) or when Mission Control exits (it renumbers/merges spaces). Both
# events reconcile the canonical labels + order via yabai_workspace_refresh. Routed
# through yabai_heal.sh, which single-flights + settles so a burst (a Mission Control
# session churning several spaces) heals exactly ONCE. refresh is idempotent (~0.34s)
# and these events are infrequent, so there is no idle/poll cost. NOT hooked to
# space_created (refresh may create a space -> would self-trigger) or window_destroyed
# (too noisy; window closes do not drop labels).
yabai -m signal --add event=space_destroyed label=heal_space_destroyed action="$YABAI_HEAL"
yabai -m signal --add event=mission_control_exit label=heal_mission_control action="$YABAI_HEAL"

# Menu-bar layers indicator (yabai_layers SwiftBar plugin): event-driven refresh.
# The plugin polls slowly (.30s) only as a backstop; these signals make it instant.
# window_focused fires for floating AND tiled windows (the handler tracks ALL windows,
# no manage guard), so it is THE event for the whole focus family: stack-layer cycle
# (hyper+z/x), mouse/cmd-tab focus onto a window with a different float/stack/type, and
# focus landing on a manage=off app (-> FLOAT). window_destroyed catches a window close
# lowering the stack depth (M). Opens (window_created) and every space switch
# (space_changed) refresh inline in those handlers above; the bsp<->stack layout toggle
# has NO yabai signal, so yabai_skhd_mode.sh pokes the refresh itself. The action is a
# sub-ms fire-and-forget URL open and SwiftBar coalesces, so no single-flight is needed.
yabai -m signal --add event=window_focused label=layers_refresh_focus action="$YABAI_LAYERS_REFRESH"
yabai -m signal --add event=window_destroyed label=layers_refresh_destroyed action="$YABAI_LAYERS_REFRESH"

# Float-window borders (yabai_float_borders.sh): reconcile the borders daemon's
# whitelist whenever the set of floating windows can change -- a window opening
# (window_created; a manage=off app or a window that starts floating) or closing
# (window_destroyed; a floater going away starts/stops the daemon). A plain
# `--toggle float` (hyper+t) emits NEITHER, so yabai_toggle_float.sh calls sync
# itself. NOT hooked to window_focused (focus doesn't change the float set; the
# daemon handles active/inactive coloring on its own) or space_changed (the
# whitelist is global -- borders only draws the visible, whitelisted windows).
yabai -m signal --add event=window_created label=border_sync_created action="$YABAI_FLOAT_BORDERS sync"
yabai -m signal --add event=window_destroyed label=border_sync_destroyed action="$YABAI_FLOAT_BORDERS sync"

# (The external-display border flash was disabled 2026-06-04 by user request. The
# helper scripts yabai_screen_flash.sh / .js remain in code/various_scripts as
# dormant; to re-enable, restore the YABAI_SCREEN_FLASH env var above and a
# `display_changed` signal with label=flash_external_display calling it.)
