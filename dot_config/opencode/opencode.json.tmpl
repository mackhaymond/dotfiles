{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-dir",
    "./plugins/chezmoi-guard.ts",
    "opencode-chrome-devtools",
    "oh-my-opencode-slim@beta"
  ],
  "agent": {
    "build": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true,
  "permission": {
    "read": {
      "*": "allow",
      "{{ .chezmoi.sourceDir }}": "allow",
      "{{ .chezmoi.sourceDir }}/**": "allow"
    },
    "bash": {
      "*": "allow"
    },
    "external_directory": {
      "*": "allow",
      "{{ .chezmoi.sourceDir }}": "allow",
      "{{ .chezmoi.sourceDir }}/**": "allow"
    },
    "edit": {
      "*": "allow",
      "{{ .chezmoi.sourceDir }}": "allow",
      "{{ .chezmoi.sourceDir }}/**": "allow",
      "{{ .chezmoi.homeDir }}/.zshrc": "deny",
      "{{ .chezmoi.homeDir }}/.zprofile": "deny",
      "{{ .chezmoi.homeDir }}/.zshenv": "deny",
      "{{ .chezmoi.homeDir }}/.zshenv.private": "deny",
      "{{ .chezmoi.homeDir }}/.gitconfig": "deny",
      "{{ .chezmoi.homeDir }}/.tmate.conf": "deny",
      "{{ .chezmoi.homeDir }}/.vimrc": "deny",
      "{{ .chezmoi.homeDir }}/.ideavimrc": "deny",
      "{{ .chezmoi.homeDir }}/.bashrc": "deny",
      "{{ .chezmoi.homeDir }}/.bash_profile": "deny",
      "{{ .chezmoi.homeDir }}/.profile": "deny"
    }
  },
  "skills": {
    "paths": [
      "{{ .chezmoi.homeDir }}/.agents/skills"
    ]
  },
  "default_agent": "orchestrator",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "enabled_providers": [
    "openai",
    "google"
  ],
  "provider": {
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
              "thinkingLevel": "medium"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": {
