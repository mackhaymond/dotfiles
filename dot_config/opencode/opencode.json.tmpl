{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent",
    "@ex-machina/opencode-anthropic-auth@1.7.5",
    "opencode-antigravity-auth@latest",
    "opencode-dir",
    "./plugins/chezmoi-guard.ts"
  ],
  "permission": {
    "bash": {
      "*": "allow"
    },
    "edit": {
      "*": "allow",
      "{{ .chezmoi.homeDir }}/.zshrc": "deny",
      "{{ .chezmoi.homeDir }}/.zprofile": "deny",
      "{{ .chezmoi.homeDir }}/.zshenv": "deny",
      "{{ .chezmoi.homeDir }}/.zshenv.private": "deny",
      "{{ .chezmoi.homeDir }}/.gitconfig": "deny",
      "{{ .chezmoi.homeDir }}/.tmate.conf": "deny",
      "{{ .chezmoi.homeDir }}/.vimrc": "deny",
      "{{ .chezmoi.homeDir }}/.ideavimrc": "deny",
      "{{ .chezmoi.homeDir }}/.bashrc": "deny",
      "{{ .chezmoi.homeDir }}/.bash_profile": "deny",
      "{{ .chezmoi.homeDir }}/.profile": "deny"
    }
  },
  "skills": {
    "paths": [
      "{{ .chezmoi.homeDir }}/.agents/skills"
    ]
  },
  "default_agent": "\u200bSisyphus - Ultraworker",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "set -eu; PORT=9222; BIND=127.0.0.1; PROFILE_DIR=/tmp/pw-cdp-profile; if command -v google-chrome >/dev/null 2>&1; then CHROME_BIN=google-chrome; elif command -v google-chrome-stable >/dev/null 2>&1; then CHROME_BIN=google-chrome-stable; elif command -v chromium >/dev/null 2>&1; then CHROME_BIN=chromium; elif command -v chromium-browser >/dev/null 2>&1; then CHROME_BIN=chromium-browser; elif command -v msedge >/dev/null 2>&1; then CHROME_BIN=msedge; elif [ -x \"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" ]; then CHROME_BIN=\"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\"; elif [ -x \"/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge\" ]; then CHROME_BIN=\"/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge\"; else echo \"No Chrome/Chromium found in PATH; install Chrome/Chromium or add it to PATH.\" >&2; exit 1; fi; mkdir -p \"$PROFILE_DIR\" >/dev/null 2>&1 || true; \"$CHROME_BIN\" --headless --remote-debugging-address=\"$BIND\" --remote-debugging-port=\"$PORT\" --user-data-dir=\"$PROFILE_DIR\" --no-first-run --no-default-browser-check --disable-dev-shm-usage >/dev/null 2>&1 & CHROME_PID=$!; trap 'kill $CHROME_PID >/dev/null 2>&1 || true' EXIT INT TERM; sleep 1; echo \"CDP: http://127.0.0.1:${PORT}/ (open chrome://inspect/#devices and add localhost:${PORT})\" >&2; npx -y @playwright/mcp@latest --headless \"--cdp-endpoint=http://127.0.0.1:${PORT}/\""
      ],
      "enabled": true
    },
    "react-grab-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@react-grab/mcp",
        "--stdio"
      ]
    }
  },
  "model": "anthropic/claude-opus-4-7",
  "enabled_providers": [
    "anthropic",
    "google",
    "openai"
  ],
  "provider": {
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } }
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        }
      }
    }
  }
}
