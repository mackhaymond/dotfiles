local wezterm = require 'wezterm'
local mux = wezterm.mux

local config = {}

if wezterm.config_builder then
    config = wezterm.config_builder()
end

wezterm.on('gui-startup', function(cmd)
    -- Start WezTerm in macOS NATIVE fullscreen by default, on whatever display it
    -- opens on. yabai then labels the resulting fullscreen Space "terminal" (via
    -- yabai_terminal_follow.sh) and reorders it to position 1, so it stays first
    -- regardless of display. Requires native_macos_fullscreen_mode = true (below).
    local _, _, window = mux.spawn_window(cmd or {})
    window:gui_window():toggle_fullscreen()
end)

config.color_scheme = "catppuccin-mocha"

config.enable_tab_bar = false
config.enable_kitty_graphics = true
-- RESIZE (no TITLE) keeps the borderless look but reports the window as
-- resizable to the OS, so yabai can size WezTerm to fill whatever display its
-- space is on. "NONE" makes the window non-resizable and yabai can't manage it.
config.window_decorations = "RESIZE"

config.font = wezterm.font_with_fallback({
    "JetBrains Mono",
    "MesloLGS NF",
})
config.font_size = 12

config.window_padding = {
    left = 0,
    right = 0,
    top = 0,
    bottom = 0,
}

config.default_prog = { "{{ .homebrew_prefix }}/bin/tmux", "new-session", "-A", "-s", "main" }

-- Use macOS NATIVE fullscreen so a fullscreened WezTerm becomes a real
-- fullscreen Space. yabai can label/reorder/focus that Space, and a space_changed
-- hook (yabai_terminal_follow.sh) keeps the "terminal" label pinned to WezTerm
-- wherever it roams -- so hyper+` still reaches it and it stays in canonical
-- order. With this false, the window drops the macOS fullscreen capability
-- entirely and yabai cannot fullscreen it.
config.native_macos_fullscreen_mode = true
config.macos_fullscreen_extend_behind_notch = true

config.window_close_confirmation = 'NeverPrompt'

config.scrollback_lines = 0

-- ── Performance ────────────────────────────────────────────────────────
config.front_end = "WebGpu"           -- explicit (default since 2024)
config.max_fps = 120                  -- match ProMotion display refresh
config.animation_fps = 1              -- minimize animation CPU
config.cursor_blink_rate = 0          -- disable blink entirely
config.use_ime = false                -- skip IME event loop (English only)

-- ── Annoyance fixes ────────────────────────────────────────────────────
config.audible_bell = "Disabled"
config.adjust_window_size_when_changing_font_size = false
config.check_for_updates = false      -- brew handles wezterm@nightly updates

config.keys = {
    {
        key = "t",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "c" }
        }
    },

    {
        key = "T",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "t", mods = "CTRL" },
        }
    },

    -- CMD+SHIFT+R: recreate current tab in place (was CMD+SHIFT+T).
    -- Sends `prefix R` to tmux (see `bind R` in tmux.conf).
    {
        key = "R",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "R", mods = "SHIFT" },
        }
    },


    {
        key = "w",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "x" },
        },
    },

    {
        key = "W",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "l", mods = "CTRL" },
        }
    },

}

for i = 1, 9 do
    table.insert(config.keys, {
        key = tostring(i),
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = tostring(i) }
        }
    })
end

return config
