local wezterm = require 'wezterm'

local config = {}

if wezterm.config_builder then
    config = wezterm.config_builder()
end

-- WezTerm starts as a NORMAL window (not fullscreen). yabai's `space=terminal`
-- rule + the window_created hook place it on the "terminal" space, which
-- yabai_reorder_spaces.sh keeps at canonical index 1, where it tiles as the
-- single stack window. You can still manually fullscreen it (hyper+fn+m); the
-- space_changed hook (yabai_terminal_follow.sh) then keeps the "terminal" label
-- pinned to WezTerm wherever the resulting fullscreen Space lands. We no longer
-- auto-fullscreen on startup (previously a gui-startup toggle_fullscreen here).

config.color_scheme = "catppuccin-mocha"

config.enable_tab_bar = false
config.enable_kitty_graphics = true
-- RESIZE (no TITLE) keeps the borderless look but reports the window as
-- resizable to the OS, so yabai can size WezTerm to fill whatever display its
-- space is on. "NONE" makes the window non-resizable and yabai can't manage it.
-- Square corners need OpenGL below; WebGPU currently initializes with the
-- wrong scale when MACOS_FORCE_SQUARE_CORNERS is present at startup.
config.window_decorations = "RESIZE|MACOS_FORCE_SQUARE_CORNERS"

config.font = wezterm.font_with_fallback({
    "JetBrains Mono",
    "MesloLGS NF",
})
config.font_size = 12

config.window_padding = {
    left = 0,
    right = 0,
    top = 0,
    bottom = 0,
}

config.default_prog = { "{{ .homebrew_prefix }}/bin/tmux", "new-session", "-A", "-s", "main" }

-- Keep macOS NATIVE fullscreen available for the MANUAL case (hyper+fn+m): a
-- fullscreened WezTerm becomes a real fullscreen Space that yabai can
-- label/reorder/focus, and the space_changed hook (yabai_terminal_follow.sh)
-- keeps the "terminal" label pinned to it wherever it roams -- so hyper+` still
-- reaches it and it stays in canonical order. WezTerm no longer fullscreens on
-- startup (see above), but this stays true so the manual toggle still works;
-- with it false the window would lose the macOS fullscreen capability entirely.
config.native_macos_fullscreen_mode = true
config.macos_fullscreen_extend_behind_notch = true

config.window_close_confirmation = 'NeverPrompt'

config.scrollback_lines = 0

-- ── Performance ────────────────────────────────────────────────────────
config.front_end = "OpenGL"           -- avoids WebGPU square-corner scaling bug
config.max_fps = 120                  -- match ProMotion display refresh
config.animation_fps = 1              -- minimize animation CPU
config.cursor_blink_rate = 0          -- disable blink entirely
config.use_ime = false                -- skip IME event loop (English only)

-- ── Annoyance fixes ────────────────────────────────────────────────────
config.audible_bell = "Disabled"
config.adjust_window_size_when_changing_font_size = false
config.check_for_updates = false      -- brew handles wezterm@nightly updates

config.keys = {
    {
        key = "t",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "c" }
        }
    },

    {
        key = "T",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "t", mods = "CTRL" },
        }
    },

    -- CMD+SHIFT+R: recreate current tab in place (was CMD+SHIFT+T).
    -- Sends `prefix R` to tmux (see `bind R` in tmux.conf).
    {
        key = "R",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "R", mods = "SHIFT" },
        }
    },


    {
        key = "w",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "x" },
        },
    },

    {
        key = "W",
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = "l", mods = "CTRL" },
        }
    },

}

for i = 1, 9 do
    table.insert(config.keys, {
        key = tostring(i),
        mods = "CMD",
        action = wezterm.action.Multiple {
            wezterm.action.SendKey { key = "s", mods = "CTRL" },
            wezterm.action.SendKey { key = tostring(i) }
        }
    })
end

return config
