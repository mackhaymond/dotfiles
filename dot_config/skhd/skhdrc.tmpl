# change focus between windows in the current AeroSpace accordion stack
hyper - z : aerospace focus --boundaries-action wrap-around-the-workspace dfs-next
hyper - x : aerospace focus --boundaries-action wrap-around-the-workspace dfs-prev

# summon workspaces to the currently focused display
hyper - 0x32: aerospace summon-workspace 1 # terminal
hyper - 1: aerospace summon-workspace 2 # main
hyper - 2: aerospace summon-workspace 3 # school
hyper - tab: aerospace summon-workspace 4 # todo
hyper - q: aerospace summon-workspace 5 # schedule
hyper - w: aerospace summon-workspace 6 # mail
hyper - e: aerospace summon-workspace 7 # calendar
hyper - d: aerospace summon-workspace 8 # messages
hyper - f: aerospace summon-workspace 9 # ChatGPT
f18 : aerospace summon-workspace 10 # Codex (caps_lock+escape -> F18)
hyper - 3: aerospace summon-workspace 11 # fullscreen video

# display targeting
f13 : aerospace focus-monitor main # hyper+F1 via Karabiner
f14 : aerospace focus-monitor secondary # hyper+F2 via Karabiner
f15 : {{ .chezmoi.homeDir }}/code/various_scripts/aerospace_swap_visible_workspaces.sh # hyper+F3 via Karabiner

# move the current window between workspaces
hyper + fn - a : aerospace move-node-to-workspace --wrap-around prev
hyper + fn - s : aerospace move-node-to-workspace --wrap-around next

# stack-focused layout controls
hyper - m: aerospace layout floating tiling
hyper + fn - m : aerospace fullscreen
hyper - b: aerospace layout accordion

# hyper - ` : open/show/hide music
# hyper - \ : enable/disable keypress recording
