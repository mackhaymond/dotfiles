# hyper+g: focus `ext` (no-op if it doesn't exist). `ext` dissolves back into main on
# hyper+0 / pushing it / undock. No-op with one display.
hyper + fn - g : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window_external.sh
hyper - g : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus ext

