# go to last space

# swap window position in a direction (bsp)
hyper + fn - j : yabai -m window --swap south
hyper + fn - k : yabai -m window --swap north
hyper + fn - h : yabai -m window --swap west
hyper + fn - l : yabai -m window --swap east

# move focus to the window in a direction (bsp; no-op in stack)
hyper - h : yabai -m window --focus west
hyper - j : yabai -m window --focus south
hyper - k : yabai -m window --focus north
hyper - l : yabai -m window --focus east

# resize focused window: [ = narrower, ] = wider, ; = shorter, ' = taller (bsp)
hyper - 0x21 : yabai -m window --resize right:-60:0
hyper - 0x1E : yabai -m window --resize right:60:0
hyper - 0x29 : yabai -m window --resize bottom:0:-60
hyper - 0x27 : yabai -m window --resize bottom:0:60

# balance: equalize all split ratios on the focused space (bsp)
hyper - b : yabai -m space --balance

# toggle the focused window's split orientation: horizontal <-> vertical (bsp)
# (hyper+s is taken by BetterTouchTool; v = vertical)
hyper - v : yabai -m window --toggle split

# rotate the whole tree 90 deg clockwise (bsp); repeat to cycle 90/180/270/0
hyper - n : yabai -m space --rotate 90

# (mirror lives on hyper+z/x in bsp -- z=horizontal, x=vertical; the old redundant
# hyper+fn+x mirror was removed)

# toggle maximize (zoom focused window to fill its space)
hyper - m : yabai -m window --toggle zoom-fullscreen

# toggle fullscreen
hyper + fn - m : yabai -m window --toggle native-fullscreen 

# toggle the focused space's layout: bsp <-> stack
hyper + fn - b : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_skhd_mode.sh
