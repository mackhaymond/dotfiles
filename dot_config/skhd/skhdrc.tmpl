# change focus between windows
hyper - z : {{ .chezmoi.homeDir }}/Desktop/coding/various_scripts/yabai_skhd_stack_next.sh
hyper - x : {{ .chezmoi.homeDir }}/Desktop/coding/various_scripts/yabai_skhd_stack_prev.sh

# change focus between spaces
# hyper - a: yabai -m space --focus prev
# hyper - s: yabai -m space --focus next

# change focus by space index
hyper - 0x32: yabai -m space --focus 1 # terminal
hyper - 1: yabai -m space --focus 2 # main
hyper - 2: yabai -m space --focus 3 # school
hyper - tab: yabai -m space --focus 4 # todo
hyper - q: yabai -m space --focus 5 # schedule
hyper - w: yabai -m space --focus 6 # mail
hyper - e: yabai -m space --focus 7 # calendar
hyper - d: yabai -m space --focus 8 # messages
hyper - f: yabai -m space --focus 9 # ChatGPT
hyper - 3: yabai -m space --focus 10 # fullscreen video

# go to last space

# swap window position in a direction
hyper + fn - j : yabai -m window --swap south
hyper + fn - k : yabai -m window --swap north
hyper + fn - h : yabai -m window --swap west
hyper + fn - l : yabai -m window --swap east

hyper + fn - a : yabai -m window --space prev
hyper + fn - s : yabai -m window --space next
# Flip the tree horizontally
hyper + fn - x : yabai -m space --mirror x-axis

# Flip the tree vertically

# toggle float
hyper - m: yabai -m window --toggle float --grid 6:6:1:1:4:4

# toggle fullscreen
hyper + fn - m : yabai -m window --toggle native-fullscreen 

# balance windows
hyper - b: {{ .chezmoi.homeDir }}/Desktop/coding/various_scripts/yabai_skhd_mode.sh

# hyper - ` : open/show/hide music
# hyper - \ : enable/disable keypress recording

# restart keybind
# hyper - 0x2A : yabai --restart-service
