# change focus between windows
hyper - z : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_skhd_stack_next.sh
hyper - x : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_skhd_stack_prev.sh

# change focus by space index
hyper - 0x32: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus terminal
hyper - 1: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus main
hyper - 2: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus school
hyper - tab: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus todo
hyper - q: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus schedule
hyper - w: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus mail
hyper - e: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus calendar
hyper - d: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus messages
hyper - f: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus chatgpt
f18 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_workspace.sh focus codex # caps_lock+escape -> F18

# hyper+3..9: focus the Nth native-fullscreen app, in mission-control order.
# Native-fullscreen apps (non-pinned apps or the browser) live in their own macOS
# Spaces outside the labeled model, so the hyper+<label> keys can't reach them.
# hyper+3 -> 1st fullscreen app, hyper+4 -> 2nd, ... no-op if that many aren't open.
hyper - 3 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 1
hyper - 4 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 2
hyper - 5 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 3
hyper - 6 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 4
hyper - 7 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 5
hyper - 8 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 6
hyper - 9 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_fullscreen_focus.sh 7

# hyper+fn+<space>: send the focused window to that space, unless it's a pinned
# app already on its home space (those stay put). Focus stays where you are.
hyper + fn - 0x32: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh terminal
hyper + fn - 1: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh main
hyper + fn - 2: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh school
hyper + fn - tab: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh todo
hyper + fn - q: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh schedule
hyper + fn - w: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh mail
hyper + fn - e: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh calendar
hyper + fn - d: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh messages
hyper + fn - f: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh chatgpt
f19 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_send_window.sh codex # fn+caps_lock+escape -> F19

f13 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_display.sh master
f14 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_display.sh external

# push the focused space to the other display (and follow); no-op on one display
hyper - 0x2A : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_space_move.sh push
# pull every labeled space home to the laptop; no-op on one display
hyper - 0 : {{ .chezmoi.homeDir }}/code/various_scripts/yabai_space_move.sh home-all

# go to last space

# swap window position in a direction
hyper + fn - j : yabai -m window --swap south
hyper + fn - k : yabai -m window --swap north
hyper + fn - h : yabai -m window --swap west
hyper + fn - l : yabai -m window --swap east

hyper + fn - a : yabai -m window --space prev
hyper + fn - s : yabai -m window --space next
# Flip the tree horizontally
hyper + fn - x : yabai -m space --mirror x-axis

# Flip the tree vertically

# toggle float
hyper - m: yabai -m window --toggle float --grid 6:6:1:1:4:4

# toggle fullscreen
hyper + fn - m : yabai -m window --toggle native-fullscreen 

# balance windows
hyper - b: {{ .chezmoi.homeDir }}/code/various_scripts/yabai_skhd_mode.sh
