#!/bin/sh
# chezmoi-approve-commit: open a 5-minute approval window for the
# chezmoi-guard plugin's CHEZMOI_COMMIT_OK escape hatch.
#
# Workflow:
#   1. user approves chezmoi commit/push activity
#   2. agent runs:  chezmoi-approve-commit
#      → writes ~/.cache/chezmoi-guard/approve-nonce
#   3. agent runs (separate bash call(s)):
#      CHEZMOI_COMMIT_OK=<anything> git -C ~/.local/share/chezmoi commit -m "..."
#      CHEZMOI_COMMIT_OK=<anything> git -C ~/.local/share/chezmoi push
#      The plugin allows any number of commits/pushes within the 5-min
#      TTL. After expiry the agent must mint again.
#
# Why a separate script (not a zsh function): non-interactive shells
# (opencode bash, scripts) don't source ~/.zshrc, so a function-based
# helper is unreachable. A binary in ~/.local/bin works everywhere PATH
# is set.
#
# Why two calls (not `CHEZMOI_COMMIT_OK=$(chezmoi-approve-commit) git commit`):
# the plugin inspects the literal command string BEFORE shell expansion,
# so it sees `$(chezmoi-approve-commit)` as text — never the actual nonce.
# The plugin only verifies that the file exists; the value passed to
# CHEZMOI_COMMIT_OK is just an "I claim approval" prefix.

set -eu

nonce_dir="${HOME}/.cache/chezmoi-guard"
nonce_file="${nonce_dir}/approve-nonce"

mkdir -p "$nonce_dir"

if command -v openssl >/dev/null 2>&1; then
  nonce=$(openssl rand -hex 16)
else
  # Fallback: 16 random bytes hex-encoded (32 chars). od strips offsets,
  # tr removes whitespace.
  nonce=$(head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n')
fi

printf '%s' "$nonce" > "$nonce_file"
chmod 600 "$nonce_file" 2>/dev/null || true

printf '[chezmoi-approve-commit] approval window open (5min TTL)\n' >&2
printf '%s\n' "$nonce"
