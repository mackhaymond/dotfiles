#!/usr/bin/env python3
"""bzcli — Backblaze CLI wrapper.

Thin shim around /Applications/Backblaze.app/Contents/MacOS/bzcli that adds
a `status` subcommand for a pretty, glow-rendered dashboard. Everything
else (including `report`) passes through unchanged.

Run `bzcli help` for the full feature list.
"""

import glob
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time
from datetime import datetime

REAL = "/Applications/Backblaze.app/Contents/MacOS/bzcli"
BZDATA = "/Library/Backblaze.bzpkg/bzdata"

WRAPPER_HELP_MD = """# 🛠️  bzcli — wrapper additions

This wrapper adds a **`status`** subcommand for a pretty, glow-rendered
dashboard. All other commands pass through unchanged to real bzcli — see
the native help below.

## `status` — pretty dashboard

Render the backup report as a styled markdown dashboard via `glow`.

| Flag                  | Description                                                |
|-----------------------|------------------------------------------------------------|
| `-q`, `--quiet`       | One-line status string, suitable for scripts               |
| `-V`, `--verbose`     | Add settings, storage, and exclusion counts                |
| `-VV`, `--all`        | Add full list of excluded directories and file extensions  |
| `-w`, `--watch [N]`   | Live mode — refresh every `N` seconds (default `5`)        |
| `--raw`               | Skip `glow`; emit raw markdown (useful for piping)         |
| `--no-color`          | Strip ANSI escapes from output                             |
| `-h`, `--help`        | Show this help                                             |

### Examples

```bash
bzcli status                # snapshot dashboard
bzcli status -q             # one-liner — perfect for tmux/sketchybar
bzcli status -V             # + settings + storage + exclusion counts
bzcli status -VV            # + every exclusion listed
bzcli status -w             # live updating dashboard (5s refresh)
bzcli status -w 10          # live, refresh every 10s
bzcli status --raw          # raw markdown (pipe to glow yourself)
```
"""


# ─── Pass-through ────────────────────────────────────────────────────


def passthrough(args):
    """Exec real bzcli with all args, preserving signals + exit code."""
    if not os.path.exists(REAL):
        sys.stderr.write(f"bzcli: real binary not found at {REAL}\n")
        sys.stderr.write("Is Backblaze installed?\n")
        sys.exit(127)
    os.execvp(REAL, [REAL] + args)


# ─── Formatting helpers ──────────────────────────────────────────────


def fmt_bytes(n):
    if n is None or n == 0:
        return "0 B"
    for div, unit in [(1024**4, "TiB"), (1024**3, "GiB"),
                      (1024**2, "MiB"), (1024, "KiB")]:
        if n >= div:
            return f"{n/div:.2f} {unit}"
    return f"{n} B"


def time_ago(last_backup):
    """`last_backup` dict → '5m ago' / '3h12m ago' / '2d ago'."""
    try:
        millis = last_backup.get("gmt_millis")
        if not millis:
            return last_backup.get("ISO8601", "never")
        s = int(datetime.now().timestamp() - millis / 1000)
        if s < 0:
            return "in the future"
        if s < 60:
            return f"{s}s ago"
        if s < 3600:
            return f"{s//60}m ago"
        if s < 86400:
            return f"{s//3600}h{(s%3600)//60}m ago"
        return f"{s//86400}d ago"
    except Exception:
        return str(last_backup)


def progress_bar(pct, width=40):
    filled = max(0, min(width, int(pct / 100 * width)))
    return "█" * filled + "░" * (width - filled)


def license_str(license_data):
    t = license_data.get("type", "?")
    status = license_data.get("status", "?")
    if status == "billing_active":
        return f"`{t}` ✅"
    if status.startswith("expires_"):
        ts = status.replace("expires_", "")
        try:
            exp = datetime.strptime(ts, "%Y%m%d%H%M%S")
            days = (exp - datetime.now()).days
            warn = " ⚠️" if days < 14 else ""
            return f"`{t}` (expires in {days}d, {exp.strftime('%Y-%m-%d')}){warn}"
        except Exception:
            pass
    return f"`{t}` ({status})"


def throttle_str(s):
    if s.get("net_auto_throttle"):
        return "auto"
    nt = s.get("net_throttle", 0)
    if nt == 100:
        return "manual / max speed"
    return f"manual / {nt}%"


def fmt_duration(seconds):
    """seconds → '5m 23s' / '2h 14m' / '1d 4h'."""
    if seconds < 0:
        return "?"
    if seconds < 60:
        return f"{int(seconds)}s"
    if seconds < 3600:
        return f"{int(seconds//60)}m {int(seconds%60)}s"
    if seconds < 86400:
        return f"{int(seconds//3600)}h {int((seconds%3600)//60)}m"
    return f"{int(seconds//86400)}d {int((seconds%86400)//3600)}h"


def get_scan_progress():
    """Return dict describing in-flight bzfilelist scan, or None."""
    fl_dir = os.path.join(BZDATA, "bzfilelists")
    if not os.path.isdir(fl_dir):
        return None

    dats = glob.glob(os.path.join(fl_dir, "v*_root_filelist.dat"))
    futures = glob.glob(os.path.join(fl_dir, "v*_root_filelist.dat.future"))
    if not futures:
        return None

    future_path = futures[0]
    future_bytes = os.path.getsize(future_path)
    future_mtime = os.path.getmtime(future_path)
    active_bytes = os.path.getsize(dats[0]) if dats else 0
    pct = (future_bytes / active_bytes * 100) if active_bytes else 0

    # Get bzfilelist process info
    proc = None
    try:
        r = subprocess.run(["pgrep", "-x", "bzfilelist"],
                           capture_output=True, text=True)
        if r.stdout.strip():
            pid = r.stdout.strip().split("\n")[0]
            ps = subprocess.run(
                ["ps", "-p", pid, "-o", "etime=,pcpu=,state=,nice="],
                capture_output=True, text=True)
            parts = ps.stdout.strip().split()
            if len(parts) >= 4:
                proc = {
                    "pid": pid,
                    "etime": parts[0],
                    "pcpu": float(parts[1]),
                    "state": parts[2],
                    "nice": int(parts[3]),
                }
    except Exception:
        pass

    # Recent scan dir from log
    current_dir = None
    log_files = glob.glob(os.path.join(BZDATA, "bzlogs/bzfilelist/*.log"))
    if log_files:
        latest_log = max(log_files, key=os.path.getmtime)
        try:
            with open(latest_log) as f:
                f.seek(0, 2)
                size = f.tell()
                f.seek(max(0, size - 100_000))
                tail = f.read()
            scans = re.findall(r"about_to_scanDir=([^,]+)", tail)
            if scans:
                current_dir = scans[-1]
        except Exception:
            pass

    # Estimate growth rate / ETA based on process etime + .future size
    eta_str = None
    rate_str = None
    if proc and active_bytes and future_bytes < active_bytes:
        # parse etime: [dd-]hh:mm:ss or mm:ss
        try:
            etime = proc["etime"]
            secs = 0
            if "-" in etime:
                d, rest = etime.split("-", 1)
                secs += int(d) * 86400
                etime = rest
            parts = [int(p) for p in etime.split(":")]
            while len(parts) < 3:
                parts.insert(0, 0)
            secs += parts[0]*3600 + parts[1]*60 + parts[2]
            if secs > 0:
                rate = future_bytes / secs  # bytes/sec
                if rate > 0:
                    remaining = active_bytes - future_bytes
                    eta_secs = remaining / rate
                    eta_str = fmt_duration(eta_secs)
                    rate_str = f"{rate/1024/1024:.2f} MiB/s avg (over {fmt_duration(secs)})"
        except Exception:
            pass

    # Activity heuristic: is .future being written to?
    age = time.time() - future_mtime
    if age < 60:
        activity = f"writing now ({int(age)}s ago)"
    elif age < 300:
        activity = f"recent write ({int(age/60)}m ago)"
    else:
        activity = f"idle ({fmt_duration(age)} since last write) — may be stalled"

    return {
        "future_bytes": future_bytes,
        "active_bytes": active_bytes,
        "pct": pct,
        "current_dir": current_dir,
        "proc": proc,
        "activity": activity,
        "eta": eta_str,
        "rate": rate_str,
    }


# ─── Markdown builders ───────────────────────────────────────────────


def build_quiet(data):
    b = data["backup"]
    f_sel = b["backup"]["files"]["selected"]
    f_rem = b["backup"]["files"]["remaining"]
    b_sel = b["backup"]["bytes"]["selected"]
    b_rem = b["backup"]["bytes"]["remaining"]
    pct = (b_sel - b_rem) / b_sel * 100 if b_sel else 0
    return (f"{b['status']['summary']}: "
            f"{f_sel-f_rem:,}/{f_sel:,} files ({pct:.1f}%) "
            f"— {b['status']['bztransmit']}")


ANSI_RE = re.compile(r"\x1b\[[0-9;]*[a-zA-Z]")


def visible_len(s):
    return len(ANSI_RE.sub("", s))


def pad_to(s, width):
    return s + " " * max(0, width - visible_len(s))


def render_glow(md, width):
    """Pipe md through glow at fixed width, return list of lines (or fallback)."""
    if not shutil.which("glow"):
        return md.splitlines()
    try:
        r = subprocess.run(
            ["glow", "-s", "dark", "-w", str(width), "-"],
            input=md.encode(), capture_output=True, check=True,
        )
        return r.stdout.decode().splitlines()
    except subprocess.CalledProcessError:
        return md.splitlines()


def join_columns(left, right, sep="  │  "):
    """Side-by-side join, ANSI-aware width padding."""
    if not right:
        return left
    width_l = max((visible_len(l) for l in left), default=0)
    rows = max(len(left), len(right))
    out = []
    for i in range(rows):
        l = left[i] if i < len(left) else ""
        r = right[i] if i < len(right) else ""
        out.append(f"{pad_to(l, width_l)}{sep}{r}")
    return out


def build_sections(data, level):
    """Return list of (md_string,) for each panel, in display order."""
    b = data["backup"]
    s = data["settings"]
    sysi = data.get("sysinfo", {})

    f_sel = b["backup"]["files"]["selected"]
    f_rem = b["backup"]["files"]["remaining"]
    b_sel = b["backup"]["bytes"]["selected"]
    b_rem = b["backup"]["bytes"]["remaining"]
    pct = (b_sel - b_rem) / b_sel * 100 if b_sel else 0

    safety = b["status"].get("safety_freeze", "?")
    safety_icon = "✅" if safety == "not_frozen" else "⚠️"
    last_obj = b["status"].get("last_backup", {})
    last = last_obj.get("ISO8601", "never")
    last_rel = time_ago(last_obj)
    summary = b["status"].get("summary", "?")

    sections = []

    # State panel
    sections.append("\n".join([
        "## ⚡ State",
        "",
        "| Field | Value |",
        "|---|---|",
        f"| Summary | **{summary}** |",
        f"| Transmitting | `{b['status'].get('bztransmit','?')}` |",
        f"| Safety | {safety} {safety_icon} |",
        f"| Last backup | _{last_rel}_ |",
        f"| License | {license_str(b['license'])} |",
    ]))

    # Machine panel
    machine_rows = [
        "## 💻 Machine",
        "",
        "| Field | Value |",
        "|---|---|",
        f"| Account | `{b['account']['email']}` |",
        f"| Hostname | {b['installation']['hostname']} |",
    ]
    if sysi:
        machine_rows += [
            f"| CPU | {sysi.get('hw.cpu.brand_string','?')} |",
            f"| RAM | {fmt_bytes(sysi.get('hw.memsize',0))} |",
            f"| macOS | {sysi.get('os.version','?')} ({sysi.get('exe.arch','?')}) |",
        ]
    sections.append("\n".join(machine_rows))

    # Selection panel
    sections.append("\n".join([
        "## 📊 Selection",
        "",
        "| Field | Value |",
        "|---|---|",
        f"| Selected | {f_sel:,} files |",
        f"| Size | {fmt_bytes(b_sel)} |",
        f"| Remaining | {f_rem:,} files / {fmt_bytes(b_rem)} |",
        f"| Progress | **{pct:.1f}%** |",
        f"| | `{progress_bar(pct, 28)}` |",
    ]))

    # Analyzing panel (only during scan)
    if summary == "Analyzing":
        scan = get_scan_progress()
        if scan:
            rows = [
                "## 🔬 Analyzing",
                "",
                "| Field | Value |",
                "|---|---|",
                f"| Progress | **{scan['pct']:.1f}%** |",
                f"| | `{progress_bar(scan['pct'], 28)}` |",
                f"| Building | {fmt_bytes(scan['future_bytes'])} / ~{fmt_bytes(scan['active_bytes'])} |",
                f"| Activity | {scan['activity']} |",
            ]
            if scan["eta"]:
                rows.append(f"| ETA | **{scan['eta']}** |")
            if scan["rate"]:
                rows.append(f"| Rate | {scan['rate']} |")
            if scan["proc"]:
                p = scan["proc"]
                rows.append(f"| Scanner | PID {p['pid']} · {p['pcpu']}% CPU · nice {p['nice']} |")
            if scan["current_dir"]:
                short = scan["current_dir"]
                if len(short) > 45:
                    short = "…" + short[-43:]
                rows.append(f"| Last dir | `{short}` |")
            sections.append("\n".join(rows))

    if level == 0:
        return sections

    # ── Settings panel ───────────────────────────────────
    sections.append("\n".join([
        "## ⚙️  Settings",
        "",
        "| Setting | Value |",
        "|---|---|",
        f"| Threads | **{s.get('num_backup_threads','?')}** |",
        f"| Throttle | {throttle_str(s)} |",
        f"| On battery | {s.get('backup_on_battery','?')} |",
        f"| Schedule | {s.get('backup_schedule_type','?')} |",
        f"| Max file | {fmt_bytes(s.get('max_filesize_mb',0)*1024*1024)} |",
        f"| Version | {b['installation'].get('version','?')} |",
        f"| Datacenter | `{b['datacenter']['cluster']}` |",
    ]))

    # ── Storage panel ────────────────────────────────────
    storage = sysi.get("storage", [])
    if storage:
        rows = [
            "## 💾 Storage",
            "",
            "| Volume | Used | Free | Total | % |",
            "|---|---|---|---|---|",
        ]
        for v in storage:
            name = v.get("user_readable_name", v.get("filepath", "?"))
            total = v.get("total_bytes", 0)
            free = v.get("free_bytes", 0)
            used = total - free
            up = (used/total*100) if total else 0
            rows.append(
                f"| {name} | {fmt_bytes(used)} | {fmt_bytes(free)} "
                f"| {fmt_bytes(total)} | {up:.0f}% |"
            )
        sections.append("\n".join(rows))

    # ── Exclusions panel ─────────────────────────────────
    dirs = [d for d in s.get("bzdirfilter_add", [])
            if d.get("whichfiles") == "none"]
    exts = [e.strip() for e in s.get("excludefiletypes_add", "").split(",")
            if e.strip()]
    sections.append("\n".join([
        "## 🚫 Exclusions",
        "",
        "| Type | Count |",
        "|---|---|",
        f"| Directories | **{len(dirs)}** |",
        f"| File extensions | **{len(exts)}** |",
    ]))

    if level >= 2:
        # Full lists as wide-spanning panels (no side-by-side)
        dir_lines = ["## All excluded directories", "", "```"]
        for d in sorted(dirs, key=lambda x: x["dir"]):
            dir_lines.append(f"  {d['dir']}")
        dir_lines.append("```")
        sections.append("\n".join(dir_lines))
        sections.append("\n".join([
            "## All excluded file extensions", "",
            "```", ", ".join(exts), "```",
        ]))

    return sections


def render_dashboard(sections, *, no_color=False):
    """Render sections as side-by-side panels (2-up where it fits)."""
    term_width = shutil.get_terminal_size((100, 24)).columns
    sep_width = 5  # "  │  "
    panel_width = max(36, (term_width - sep_width) // 2)

    # Header (full-width)
    header_lines = render_glow("# 📦 Backblaze Backup Status\n", term_width)
    out = list(header_lines)

    # Decide which sections go wide (no pairing) vs paired
    # Heuristic: panels with raw ``` code blocks (verbose -VV) go full width
    panels = []
    full_width = []
    for md in sections:
        if "```" in md:
            full_width.append(md)
        else:
            panels.append(md)

    # Render and pair the regular panels 2-up
    rendered = [render_glow(md, panel_width) for md in panels]
    for i in range(0, len(rendered), 2):
        left = rendered[i]
        right = rendered[i + 1] if i + 1 < len(rendered) else None
        out += join_columns(left, right)

    # Append full-width panels
    for md in full_width:
        out += render_glow(md, term_width)

    text = "\n".join(out)
    if no_color:
        text = ANSI_RE.sub("", text)
    print(text)


# ─── Rendering ───────────────────────────────────────────────────────


def render(md, *, use_glow=True, no_color=False):
    if use_glow and shutil.which("glow"):
        try:
            subprocess.run(["glow", "-s", "dark", "-"],
                           input=md.encode(), check=True)
            return
        except subprocess.CalledProcessError:
            pass
    if no_color:
        # strip backticks etc. for cleanest text output
        md = md.replace("`", "")
    print(md)


def strip_ansi(text):
    import re
    return re.sub(r"\x1b\[[0-9;]*[a-zA-Z]", "", text)


# ─── Data fetch ──────────────────────────────────────────────────────


def fetch_report():
    p = subprocess.run([REAL, "report"], capture_output=True, text=True)
    if p.returncode != 0:
        sys.stderr.write(p.stderr or "bzcli failed\n")
        sys.exit(p.returncode)
    try:
        return json.loads(p.stdout)
    except json.JSONDecodeError as e:
        sys.stderr.write(f"bzcli returned non-JSON: {e}\n")
        sys.exit(1)


# ─── Status subcommand ───────────────────────────────────────────────


def parse_status_args(args):
    """Returns (mode, level, raw, no_color, watch_seconds).
    mode: 'quiet' | 'pretty' | 'help'
    level: 0 (default) | 1 (-V) | 2 (-VV)
    """
    mode = "pretty"
    level = 0
    raw = False
    no_color = False
    watch = None

    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-h", "--help"):
            mode = "help"
        elif a in ("-q", "--quiet"):
            mode = "quiet"
        elif a == "-VV" or a == "--all":
            level = 2
        elif a in ("-V", "--verbose"):
            level = 1
        elif a == "--raw":
            raw = True
        elif a == "--no-color":
            no_color = True
        elif a in ("-w", "--watch"):
            watch = 5
            # peek next arg for optional N
            if i + 1 < len(args) and args[i + 1].isdigit():
                watch = int(args[i + 1])
                i += 1
        else:
            sys.stderr.write(f"bzcli status: unknown flag '{a}'\n")
            sys.stderr.write("Run `bzcli help` for usage.\n")
            sys.exit(2)
        i += 1

    return mode, level, raw, no_color, watch


def cmd_status(args):
    mode, level, raw, no_color, watch = parse_status_args(args)

    if mode == "help":
        render(WRAPPER_HELP_MD)
        return

    def once():
        data = fetch_report()
        if mode == "quiet":
            line = build_quiet(data)
            print(strip_ansi(line) if no_color else line)
            return
        sections = build_sections(data, level)
        if raw or not shutil.which("glow"):
            # Raw: just concatenate the markdown sections vertically
            print("\n\n".join(["# 📦 Backblaze Backup Status"] + sections))
        else:
            render_dashboard(sections, no_color=no_color)

    if watch:
        # Live mode: alt-screen buffer + cursor-home overwrite = no flicker.
        # \033[?1049h enters alt screen, \033[?25l hides cursor,
        # \033[H homes cursor, \033[J clears from cursor down.
        # On exit (Ctrl-C), restore cursor + alt screen.
        sys.stdout.write("\033[?1049h\033[?25l")
        sys.stdout.flush()
        try:
            while True:
                sys.stdout.write("\033[H")  # home, don't clear yet
                once()
                sys.stdout.write(
                    f"\n[refreshing every {watch}s — Ctrl-C to exit]\n"
                    f"\033[J"  # clear from cursor to end (erases leftover lines)
                )
                sys.stdout.flush()
                time.sleep(watch)
        except KeyboardInterrupt:
            pass
        finally:
            sys.stdout.write("\033[?25h\033[?1049l")  # show cursor, exit alt screen
            sys.stdout.flush()
        return

    once()


# ─── Help subcommand ─────────────────────────────────────────────────


def cmd_help():
    """Render wrapper-specific help, then append native bzcli --help."""
    render(WRAPPER_HELP_MD)
    sys.stdout.write("\n")
    sys.stdout.flush()
    if os.path.exists(REAL):
        subprocess.run([REAL, "--help"])


# ─── Entry ───────────────────────────────────────────────────────────


def main():
    args = sys.argv[1:]

    # Help (wrapper-level)
    if not args or args[0] in ("help", "-h", "--help"):
        cmd_help()
        return

    # Pretty status subcommand
    if args[0] == "status":
        cmd_status(args[1:])
        return

    # Everything else → real bzcli, unchanged
    passthrough(args)


if __name__ == "__main__":
    main()
