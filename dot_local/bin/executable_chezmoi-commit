#!/usr/bin/env bash
#
# chezmoi-commit — split pending chezmoi *source* changes into logical commits,
# write a message for each with a fast/cheap model, commit, and push.
#
# AI backend: claude CLI (haiku) first; falls back to codex CLI if claude fails.
# Does NOT run `chezmoi re-add` — it only commits what's already changed in the
# chezmoi source repo (edit via `chezmoi edit` or directly, then run this).
#
# Usage:
#   chezmoi-commit            # group, commit, and push
#   chezmoi-commit --dry-run  # show the planned commits, change nothing
#   chezmoi-commit --no-push  # commit but don't push
#
# Env overrides:
#   CHEZMOI_COMMIT_CLAUDE_MODEL  (default: haiku)
#   CHEZMOI_COMMIT_CODEX_MODEL   (default: gpt-5.4-mini, run at low reasoning
#                                 effort to keep the fallback fast/cheap)

set -euo pipefail

DRY_RUN=0
PUSH=1
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    --no-push) PUSH=0 ;;
    -h|--help) sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown arg: $arg" >&2; exit 2 ;;
  esac
done

CLAUDE_MODEL="${CHEZMOI_COMMIT_CLAUDE_MODEL:-haiku}"
CODEX_MODEL="${CHEZMOI_COMMIT_CODEX_MODEL:-gpt-5.4-mini}"

die() { echo "chezmoi-commit: $*" >&2; exit 1; }

command -v chezmoi >/dev/null || die "chezmoi not found"
command -v jq >/dev/null || die "jq not found"

SRC="$(chezmoi source-path)" || die "could not resolve chezmoi source-path"
cd "$SRC" || die "could not cd into $SRC"

# Bail early if the source repo is clean.
if [ -z "$(git status --porcelain)" ]; then
  echo "Nothing to commit in $SRC"
  exit 0
fi

# The authoritative set of changed paths (tracked modifications + untracked),
# NUL-safe. We only ever commit files that appear here.
mapfile -d '' -t CHANGED < <(git status -z --porcelain | \
  while IFS= read -r -d '' entry; do
    # entry looks like "XY path"; rename entries ("R  old -> new") need the new path.
    path="${entry:3}"
    case "${entry:0:2}" in
      R*|C*) read -r -d '' next || true; path="${path##* -> }" ;;
    esac
    printf '%s\0' "$path"
  done)

[ "${#CHANGED[@]}" -gt 0 ] || die "no changed files resolved"

# Build the context we hand to the model: porcelain status + a size-capped diff
# (staged + unstaged) + names of untracked files so it can group them too.
CONTEXT="$(
  printf '## git status\n'
  git -c color.ui=never status --short
  printf '\n## diff (tracked changes, truncated)\n'
  git -c color.ui=never diff HEAD -- . | head -c 60000
  printf '\n## untracked files\n'
  git ls-files --others --exclude-standard
)"

read -r -d '' INSTRUCTIONS <<'EOF' || true
You are organizing pending git changes in a chezmoi dotfiles repo into a small
number of LOGICAL commits. A logical commit groups changes that belong to the
same app/feature/intent (e.g. all wezterm tweaks together, all shell aliases
together). Prefer few cohesive commits over many tiny ones.

Return ONLY a JSON object, no prose, no markdown fences, of exactly this shape:
{"groups":[{"message":"<conventional, imperative, <=72 chars>","files":["<path>", ...]}]}

Rules:
- Use the EXACT file paths from the status/untracked lists below.
- Every changed file must appear in exactly one group.
- Do not invent paths. Do not include unchanged files.
- Messages: conventional-commit style when natural (e.g. "feat(wezterm): ...",
  "chore(zsh): ..."), concise, imperative mood, no trailing period.
EOF

PROMPT="$INSTRUCTIONS

# Repository changes
$CONTEXT"

# --- Ask the model for the grouping JSON --------------------------------------

# Strip markdown code fences and isolate the JSON object.
extract_json() {
  sed -e 's/^```[a-zA-Z]*$//' -e 's/^```$//' | \
    awk 'BEGIN{d=0} {for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c=="{")d++; if(d>0)printf "%s",c; if(c=="}"){d--; if(d==0)printf "\n"}}}'
}

GROUPS_JSON=""

try_claude() {
  command -v claude >/dev/null || return 1
  local out
  # Unset ANTHROPIC_API_KEY so claude authenticates via the OAuth subscription
  # (Pro/Max) instead of billing the API credit balance.
  # Strip the agent harness for speed: no MCP servers (--strict-mcp-config +
  # empty config skips spawning codegraph/context7), no skills/hooks/settings
  # (--setting-sources ''), and no tools (--disallowed-tools '*'). This is a
  # pure one-shot text completion, so none of that is needed.
  out="$(printf '%s' "$PROMPT" | env -u ANTHROPIC_API_KEY claude -p --model "$CLAUDE_MODEL" \
    --output-format json \
    --strict-mcp-config --mcp-config '{"mcpServers":{}}' \
    --setting-sources '' \
    --disallowed-tools '*' 2>/dev/null)" || return 1
  # Surface API/billing failures clearly instead of silently falling through.
  if [ "$(printf '%s' "$out" | jq -r '.is_error // false' 2>/dev/null)" = "true" ]; then
    echo "claude error: $(printf '%s' "$out" | jq -r '.result // "unknown"')" >&2
    return 1
  fi
  # --output-format json wraps the model text in .result
  out="$(printf '%s' "$out" | jq -r '.result // empty' 2>/dev/null)" || return 1
  [ -n "$out" ] || return 1
  out="$(printf '%s' "$out" | extract_json)"
  printf '%s' "$out" | jq -e '.groups | type == "array"' >/dev/null 2>&1 || return 1
  GROUPS_JSON="$out"
}

try_codex() {
  command -v codex >/dev/null || return 1
  local schema last
  schema="$(mktemp)"; last="$(mktemp)"
  cat >"$schema" <<'JSON'
{
  "type": "object",
  "additionalProperties": false,
  "required": ["groups"],
  "properties": {
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["message", "files"],
        "properties": {
          "message": {"type": "string"},
          "files": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
JSON
  codex exec \
    -m "$CODEX_MODEL" \
    -c model_reasoning_effort="low" \
    --skip-git-repo-check \
    --output-schema "$schema" \
    -o "$last" \
    "$PROMPT" >/dev/null 2>&1 || { rm -f "$schema" "$last"; return 1; }
  local out; out="$(cat "$last" | extract_json)"
  rm -f "$schema" "$last"
  printf '%s' "$out" | jq -e '.groups | type == "array"' >/dev/null 2>&1 || return 1
  GROUPS_JSON="$out"
}

echo "Grouping changes with $CLAUDE_MODEL (claude)…" >&2
if ! try_claude; then
  echo "claude failed; falling back to codex ($CODEX_MODEL)…" >&2
  try_codex || die "both claude and codex failed to produce a grouping"
fi

# --- Validate the grouping against the real changed set -----------------------

# Write the actual changed paths to a temp file for jq membership checks.
CHANGED_FILE="$(mktemp)"
printf '%s\n' "${CHANGED[@]}" >"$CHANGED_FILE"

# Keep only files that genuinely changed (drop hallucinated paths).
GROUPS_JSON="$(jq --rawfile changed "$CHANGED_FILE" '
  ($changed | rtrimstr("\n") | split("\n")) as $valid
  | {groups: [ .groups[]
      | .files |= map(select(. as $f | $valid | index($f)))
      | select(.files | length > 0) ]}
' <<<"$GROUPS_JSON")" || die "failed to validate grouping JSON"

NGROUPS="$(jq '.groups | length' <<<"$GROUPS_JSON")"
[ "$NGROUPS" -gt 0 ] || die "model returned no usable groups"

# Any changed file the model forgot? Sweep it into a final catch-all commit.
COVERED="$(jq -r '.groups[].files[]' <<<"$GROUPS_JSON" | sort -u)"
MISSING="$(comm -23 <(printf '%s\n' "${CHANGED[@]}" | sort -u) <(printf '%s' "$COVERED"))"
if [ -n "$MISSING" ]; then
  GROUPS_JSON="$(jq --arg msg "chore: commit remaining dotfile changes" \
    --slurpfile m <(printf '%s\n' "$MISSING" | jq -R . | jq -s .) \
    '.groups += [{message: $msg, files: $m[0]}]' <<<"$GROUPS_JSON")"
  NGROUPS=$((NGROUPS + 1))
fi

# --- Show the plan ------------------------------------------------------------

echo
echo "Planned commits ($NGROUPS):"
jq -r '.groups | to_entries[] | "  \(.key+1). \(.value.message)\n" + (.value.files | map("       - " + .) | join("\n"))' <<<"$GROUPS_JSON"
echo

if [ "$DRY_RUN" -eq 1 ]; then
  echo "(dry run — nothing committed)"
  exit 0
fi

# --- Commit each group --------------------------------------------------------

# Start from a clean stage so each group commits only its own files.
git reset -q

COMMITS=0
while IFS= read -r grp; do
  msg="$(jq -r '.message' <<<"$grp")"
  mapfile -t files < <(jq -r '.files[]' <<<"$grp")
  [ "${#files[@]}" -gt 0 ] || continue
  git add -- "${files[@]}"
  if git diff --cached --quiet; then
    continue  # nothing actually staged for this group
  fi
  git commit -q -m "$msg"
  echo "✓ $msg"
  COMMITS=$((COMMITS + 1))
done < <(jq -c '.groups[]' <<<"$GROUPS_JSON")

[ "$COMMITS" -gt 0 ] || die "nothing was committed"

# --- Push ---------------------------------------------------------------------

if [ "$PUSH" -eq 1 ]; then
  echo "Pushing $COMMITS commit(s)…"
  git push
  echo "Done."
else
  echo "Committed $COMMITS group(s); skipped push (--no-push)."
fi
