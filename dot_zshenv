# ~/.zshenv - sourced for ALL zsh invocations. Keep minimal.

# XDG
export XDG_CONFIG_HOME="$HOME/.config"

# Editor + locale
export EDITOR="nvim"
export LC_ALL=en_US.UTF-8

# pyenv shims on PATH for non-login/non-interactive shells. .zprofile (which
# does the canonical setup) is login-only - scripts, `zsh -c`, IDE terminals,
# and non-login interactive shells would otherwise resolve `python3` to system
# Python. Variable-based: $PYENV_ROOT/shims is pyenv's stable layout (since
# 2012). Idempotent with .zprofile (typeset -U in .zprofile dedups).
export PYENV_ROOT="${PYENV_ROOT:-$HOME/.pyenv}"
[[ -d "$PYENV_ROOT/shims" ]] && export PATH="$PYENV_ROOT/shims:$PATH"

# 1Password service-account token from macOS Keychain. Used by chezmoi
# templating (op:// references) and by the drift indicator's background
# `chezmoi verify` call — both need non-interactive auth in subprocess
# contexts (opencode, cron, IDE terminals, &! subshells) where biometric
# / desktop-app prompts can't reach a TTY. Keychain entry is created
# manually via `security add-generic-password -s op-service-account-token`.
# Lookup is ~10ms; the `-z` guard keeps child shells free since they
# inherit from parent.
if [[ -z "$OP_SERVICE_ACCOUNT_TOKEN" ]] && command -v security >/dev/null 2>&1; then
  export OP_SERVICE_ACCOUNT_TOKEN="$(security find-generic-password \
    -s op-service-account-token -a "$USER" -w 2>/dev/null)"
fi

# Secrets (chmod 600, gitignored)
[[ -r "$HOME/.zshenv.private" ]] && source "$HOME/.zshenv.private"
